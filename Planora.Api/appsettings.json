{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "Default": ""
  },
  "Jwt": {
    "Key": "",
    "Issuer": "Planora.Api",
    "Audience": "Planora.Web",
    "ExpirationMinutes": "15",
    "RefreshTokenDays": "7"
  },
  "App": {
    "WebBaseUrl": ""
  },
  "Cors": {
    "AllowedOrigins": ""
  },
  "Storage": {
    "Provider": "Local",
    "Blob": {
      "ConnectionString": "",
      "ContainerName": "uploads",
      "PublicBaseUrl": ""
    }
  },
  "Email": {
    "Provider": "Console",
    "Domain": "planora.website",
    "From": {
      "Address": "notifications@planora.website",
      "Name": "Planora"
    },
    "Senders": {
      "NoReply": { "LocalPart": "no-reply", "Name": "Planora" },
      "Security": { "LocalPart": "security", "Name": "Planora Security" },
      "Invites": { "LocalPart": "invites", "Name": "Planora Invitations" },
      "Notifications": { "LocalPart": "notifications", "Name": "Planora" },
      "Support": { "LocalPart": "support", "Name": "Planora Support" }
    },
    "Resend": {
      "ApiKey": ""
    }
  },
  "Cleanup": {
    "IntervalHours": 6,
    "TrashRetentionDays": 30
  }
}
