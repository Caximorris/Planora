{
  "globalHeaders": {
    "Blazor-Environment": "Production",
    "Cache-Control": "no-cache, must-revalidate",
    "X-Frame-Options": "DENY",
    "X-Content-Type-Options": "nosniff",
    "Referrer-Policy": "strict-origin-when-cross-origin",
    "Permissions-Policy": "camera=(), microphone=(), geolocation=()",
    "Content-Security-Policy": "default-src 'self'; script-src 'self' 'unsafe-inline' 'wasm-unsafe-eval' blob:; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; img-src 'self' data: blob: https:; font-src 'self' data: https://fonts.gstatic.com; connect-src 'self' https:; worker-src blob:; frame-ancestors 'none'; object-src 'none'; base-uri 'self';"
  },
  "routes": [
    {
      "route": "/index.html",
      "headers": { "Cache-Control": "no-cache, must-revalidate" }
    },
    {
      "route": "/version.json",
      "headers": { "Cache-Control": "no-cache, must-revalidate" }
    },
    {
      "route": "/service-worker.js",
      "headers": { "Cache-Control": "no-cache, must-revalidate" }
    },
    {
      "route": "/service-worker.published.js",
      "headers": { "Cache-Control": "no-cache, must-revalidate" }
    },
    {
      "route": "/service-worker-assets.js",
      "headers": { "Cache-Control": "no-cache, must-revalidate" }
    },
    {
      "route": "/appsettings.json",
      "headers": { "Cache-Control": "no-cache, must-revalidate" }
    },
    {
      "route": "/_framework/blazor.boot.json",
      "headers": { "Cache-Control": "no-cache, must-revalidate" }
    },
    {
      "route": "/_framework/dotnet.js",
      "headers": { "Cache-Control": "no-cache, must-revalidate" }
    },
    {
      "route": "/_framework/*",
      "headers": { "Cache-Control": "public, max-age=31536000, immutable" }
    },
    {
      "route": "/css/*",
      "headers": { "Cache-Control": "public, max-age=31536000, immutable" }
    },
    {
      "route": "/lib/*",
      "headers": { "Cache-Control": "public, max-age=31536000, immutable" }
    },
    {
      "route": "/js/cover-cropper.js",
      "headers": { "Cache-Control": "no-cache, must-revalidate" }
    },
    {
      "route": "/js/*",
      "headers": { "Cache-Control": "public, max-age=31536000, immutable" }
    }
  ],
  "navigationFallback": {
    "rewrite": "/index.html",
    "exclude": [
      "/_framework/*",
      "/css/*",
      "/js/*",
      "/lib/*",
      "*.{ico,png,jpg,gif,svg,woff,woff2,ttf}"
    ]
  },
  "mimeTypes": {
    ".dll": "application/octet-stream",
    ".blat": "application/octet-stream",
    ".dat": "application/octet-stream",
    ".wasm": "application/wasm"
  }
}
