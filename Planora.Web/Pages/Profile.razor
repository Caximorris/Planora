@page "/profile"
@attribute [Authorize]
@using Planora.Shared.DTOs.Users

<PageTitle>Profile — Planora</PageTitle>

<AuthorizeView>
    <Authorized>
        <div class="profile-root">
            <div class="profile-header">
                <div class="profile-avatar-lg">
                    @(_displayName.Length > 0 ? _displayName[0].ToString().ToUpper() : "?")
                </div>
                <div>
                    <h1>@(_displayName.Length > 0 ? _displayName : "Account")</h1>
                    <p>@context.User.FindFirst("email")?.Value</p>
                </div>
            </div>

            <div class="profile-section">
                <h2 class="profile-section-title">Account</h2>
                <div class="profile-row">
                    <div>
                        <div class="profile-row-label">Display name</div>
                        <div class="profile-row-desc">The name other members see on your cards and boards</div>
                    </div>
                    <div class="d-flex gap-2 align-items-center">
                        <input class="form-control profile-row-input"
                               @bind="_displayName"
                               maxlength="50"
                               placeholder="Your display name" />
                        <button class="btn btn-primary btn-sm" @onclick="SaveDisplayName" disabled="@_savingName">
                            @if (_savingName) { <span class="spinner-border spinner-border-sm me-1"></span> }
                            Save
                        </button>
                    </div>
                </div>
                @if (_nameSuccess is not null)
                {
                    <div class="alert @(_nameSuccess == true ? "alert-success" : "alert-danger") py-1 mt-1" style="font-size:13px;">
                        @_nameMessage
                    </div>
                }
                <div class="profile-row">
                    <div>
                        <div class="profile-row-label">Email</div>
                        <div class="profile-row-desc">@(_emailConfirmed ? "Verified for account recovery" : "Not verified")</div>
                    </div>
                    <div class="profile-email-actions">
                        <input class="form-control profile-row-input" value="@_email" disabled />
                        @if (_emailConfirmed)
                        {
                            <span class="profile-status-badge profile-status-badge--success">Verified</span>
                        }
                        else
                        {
                            <button type="button" class="btn btn-secondary btn-sm" @onclick="SendEmailConfirmation" disabled="@_sendingVerification">
                                @if (_sendingVerification) { <span class="spinner-border spinner-border-sm me-1"></span> }
                                Send verification
                            </button>
                        }
                    </div>
                </div>
                @if (_emailVerifyMessage is not null)
                {
                    <div class="alert @(_emailVerifySuccess == true ? "alert-success" : "alert-danger") py-1 mt-1" style="font-size:13px;">
                        @_emailVerifyMessage
                    </div>
                }
            </div>

            <div class="profile-section">
                <h2 class="profile-section-title">Appearance</h2>
                <div class="profile-row">
                    <div>
                        <div class="profile-row-label">Theme</div>
                        <div class="profile-row-desc">Choose how Planora looks on your device</div>
                    </div>
                    <div class="profile-theme-options">
                        <button type="button" class="profile-theme-btn @(_theme == "light" ? "profile-theme-btn--active" : "")" @onclick='() => SetTheme("light")'>☀️ Light</button>
                        <button type="button" class="profile-theme-btn @(_theme == "dark" ? "profile-theme-btn--active" : "")" @onclick='() => SetTheme("dark")'>🌙 Dark</button>
                    </div>
                </div>
            </div>

            <div class="profile-section">
                <h2 class="profile-section-title">Security</h2>
                <div class="profile-row">
                    <div>
                        <div class="profile-row-label">Password</div>
                        <div class="profile-row-desc">Change your account password</div>
                    </div>
                    <button type="button" class="btn btn-secondary btn-sm" @onclick="() => _showChangePwd = !_showChangePwd">
                        @(_showChangePwd ? "Cancel" : "Change password")
                    </button>
                </div>

                @if (_showChangePwd)
                {
                    <div class="mt-2 mb-2" style="max-width:380px;">
                        <div class="mb-2">
                            <label class="form-label" style="font-size:13px;">Current password</label>
                            <input type="password" class="form-control form-control-sm" @bind="_currentPwd" />
                        </div>
                        <div class="mb-2">
                            <label class="form-label" style="font-size:13px;">New password</label>
                            <input type="password" class="form-control form-control-sm" @bind="_newPwd" />
                        </div>
                        <div class="mb-3">
                            <label class="form-label" style="font-size:13px;">Confirm new password</label>
                            <input type="password" class="form-control form-control-sm" @bind="_confirmPwd" />
                        </div>
                        @if (_pwdMessage is not null)
                        {
                            <div class="alert @(_pwdSuccess == true ? "alert-success" : "alert-danger") py-1 mb-2" style="font-size:13px;">
                                @_pwdMessage
                            </div>
                        }
                        <button class="btn btn-primary btn-sm" @onclick="ChangePassword" disabled="@_savingPwd">
                            @if (_savingPwd) { <span class="spinner-border spinner-border-sm me-1"></span> }
                            Update password
                        </button>
                    </div>
                }

                <div class="profile-row">
                    <div>
                        <div class="profile-row-label">Two-factor authentication</div>
                        <div class="profile-row-desc">Require a code from your authenticator app when signing in</div>
                    </div>
                    <div class="d-flex gap-2 align-items-center">
                        @if (_twoFaLoading)
                        {
                            <span class="spinner-border spinner-border-sm"></span>
                        }
                        else if (_twoFaEnabled)
                        {
                            <span class="profile-status-badge profile-status-badge--success">Enabled</span>
                            <button type="button" class="btn btn-secondary btn-sm" @onclick="ToggleRegen" disabled="@_twoFaBusy">Recovery codes</button>
                            <button type="button" class="btn btn-outline-danger btn-sm" @onclick="ToggleDisable" disabled="@_twoFaBusy">Disable</button>
                        }
                        else if (_setup is null && _recoveryCodes is null)
                        {
                            <button type="button" class="btn btn-primary btn-sm" @onclick="StartSetup" disabled="@_twoFaBusy">
                                @if (_twoFaBusy) { <span class="spinner-border spinner-border-sm me-1"></span> }
                                Enable
                            </button>
                        }
                    </div>
                </div>

                @if (_twoFaError is not null)
                {
                    <div class="alert alert-danger py-1 mt-1" style="font-size:13px;">@_twoFaError</div>
                }

                @* Enrollment: QR + manual key + confirm code *@
                @if (_setup is not null)
                {
                    <div class="twofa-panel">
                        <ol class="twofa-steps">
                            <li>In Google Authenticator, Authy, or 1Password, add an account by entering this key:</li>
                        </ol>
                        <div class="twofa-key-row">
                            <code class="twofa-key">@_setup.SharedKey</code>
                            <a class="btn btn-secondary btn-sm" href="@_setup.AuthenticatorUri">Open in authenticator app</a>
                        </div>
                        <div class="twofa-enroll-form mt-2">
                            <label class="form-label" style="font-size:13px;">Then enter the 6-digit code it shows</label>
                            <input class="form-control form-control-sm" @bind="_enableCode" inputmode="numeric"
                                   autocomplete="one-time-code" placeholder="123456" style="max-width:180px;" />
                            <div class="d-flex gap-2 mt-2">
                                <button class="btn btn-primary btn-sm" @onclick="ConfirmEnable" disabled="@_twoFaBusy">
                                    @if (_twoFaBusy) { <span class="spinner-border spinner-border-sm me-1"></span> }
                                    Verify &amp; enable
                                </button>
                                <button class="btn btn-secondary btn-sm" @onclick="CancelSetup" disabled="@_twoFaBusy">Cancel</button>
                            </div>
                        </div>
                    </div>
                }

                @* Recovery codes — shown once after enable / regenerate *@
                @if (_recoveryCodes is not null)
                {
                    <div class="twofa-panel">
                        <div class="twofa-recovery-head">
                            <strong>Save your recovery codes</strong>
                            <p class="profile-row-desc">
                                Store these somewhere safe. Each can be used once to sign in if you lose your device.
                                They won't be shown again.
                            </p>
                        </div>
                        <div class="twofa-recovery-grid">
                            @foreach (var rc in _recoveryCodes)
                            {
                                <code class="twofa-recovery-code" @key="rc">@rc</code>
                            }
                        </div>
                        <button class="btn btn-primary btn-sm mt-2" @onclick="DismissRecoveryCodes">I've saved these</button>
                    </div>
                }

                @* Disable — requires a code *@
                @if (_showDisable)
                {
                    <div class="twofa-panel" style="max-width:380px;">
                        <label class="form-label" style="font-size:13px;">Enter a code to confirm disabling 2FA</label>
                        <input class="form-control form-control-sm" @bind="_disableCode"
                               autocomplete="one-time-code" placeholder="@(_disableUseRecovery ? "recovery code" : "123456")" />
                        <div class="form-check mt-2" style="font-size:13px;">
                            <input class="form-check-input" type="checkbox" id="disableRecovery" @bind="_disableUseRecovery" />
                            <label class="form-check-label" for="disableRecovery">I'm using a recovery code</label>
                        </div>
                        <div class="d-flex gap-2 mt-2">
                            <button class="btn btn-outline-danger btn-sm" @onclick="ConfirmDisable" disabled="@_twoFaBusy">
                                @if (_twoFaBusy) { <span class="spinner-border spinner-border-sm me-1"></span> }
                                Disable 2FA
                            </button>
                            <button class="btn btn-secondary btn-sm" @onclick="ToggleDisable" disabled="@_twoFaBusy">Cancel</button>
                        </div>
                    </div>
                }

                @* Regenerate recovery codes — requires a TOTP *@
                @if (_showRegen)
                {
                    <div class="twofa-panel" style="max-width:380px;">
                        <label class="form-label" style="font-size:13px;">Enter your current authenticator code to get new recovery codes</label>
                        <input class="form-control form-control-sm" @bind="_regenCode" inputmode="numeric"
                               autocomplete="one-time-code" placeholder="123456" />
                        <div class="d-flex gap-2 mt-2">
                            <button class="btn btn-primary btn-sm" @onclick="ConfirmRegen" disabled="@_twoFaBusy">
                                @if (_twoFaBusy) { <span class="spinner-border spinner-border-sm me-1"></span> }
                                Regenerate
                            </button>
                            <button class="btn btn-secondary btn-sm" @onclick="ToggleRegen" disabled="@_twoFaBusy">Cancel</button>
                        </div>
                    </div>
                }
                <div class="profile-row">
                    <div>
                        <div class="profile-row-label">Active sessions</div>
                        <div class="profile-row-desc">See and manage where you're signed in</div>
                    </div>
                    <button type="button" class="btn btn-secondary btn-sm" @onclick="ToggleSessions">
                        @(_showSessions ? "Hide" : "Manage")
                    </button>
                </div>
                @if (_showSessions)
                {
                    <div class="session-panel">
                        <div class="session-toolbar">
                            <button type="button" class="btn btn-secondary btn-sm" @onclick="() => LoadSessions()" disabled="@_loadingSessions">
                                @if (_loadingSessions) { <span class="spinner-border spinner-border-sm me-1"></span> }
                                Refresh
                            </button>
                            <button type="button" class="btn btn-outline-danger btn-sm" @onclick="RevokeOtherSessions" disabled="@(_savingSessions || !_sessions.Any(s => !s.IsCurrent))">
                                Revoke others
                            </button>
                        </div>
                        @if (_sessionsMessage is not null)
                        {
                            <div class="alert @(_sessionsSuccess == true ? "alert-success" : "alert-danger") py-1 mb-2" style="font-size:13px;">
                                @_sessionsMessage
                            </div>
                        }
                        @if (_loadingSessions)
                        {
                            <div class="session-loading">
                                <span class="spinner-border spinner-border-sm me-2"></span>
                                Loading sessions...
                            </div>
                        }
                        else if (_sessions.Count == 0)
                        {
                            <div class="session-empty">No active sessions found.</div>
                        }
                        else
                        {
                            <div class="session-list">
                                @foreach (var session in _sessions)
                                {
                                    <div class="session-item" @key="session.Id">
                                        <div>
                                            <div class="session-title">
                                                @(session.IsCurrent ? "Current session" : "Signed-in session")
                                            </div>
                                            <div class="session-meta">
                                                Created @FormatSessionTime(session.CreatedAt) · Expires @FormatSessionTime(session.ExpiresAt)
                                            </div>
                                        </div>
                                        @if (session.IsCurrent)
                                        {
                                            <span class="profile-status-badge profile-status-badge--success">Current</span>
                                        }
                                        else
                                        {
                                            <button type="button" class="btn btn-outline-danger btn-sm"
                                                    @onclick="() => RevokeSession(session.Id)"
                                                    disabled="@_savingSessions">
                                                Revoke
                                            </button>
                                        }
                                    </div>
                                }
                            </div>
                        }
                    </div>
                }
            </div>

            <div class="profile-section">
                <h2 class="profile-section-title">Notifications</h2>
                @if (_prefs is null)
                {
                    <div class="profile-row"><span class="spinner-border spinner-border-sm"></span></div>
                }
                else
                {
                    <div class="profile-row">
                        <div>
                            <div class="profile-row-label">Assigned to a card</div>
                            <div class="profile-row-desc">Email me when someone assigns me to a card</div>
                        </div>
                        <div class="form-check form-switch">
                            <input class="form-check-input" type="checkbox" role="switch" @bind="_prefs.EmailOnAssigned" />
                        </div>
                    </div>
                    <div class="profile-row">
                        <div>
                            <div class="profile-row-label">Comments on my cards</div>
                            <div class="profile-row-desc">Email me when someone comments on a card I'm assigned to</div>
                        </div>
                        <div class="form-check form-switch">
                            <input class="form-check-input" type="checkbox" role="switch" @bind="_prefs.EmailOnComment" />
                        </div>
                    </div>
                    <div class="profile-row">
                        <div>
                            <div class="profile-row-label">Workspace invitations</div>
                            <div class="profile-row-desc">Email me when I'm invited to a workspace</div>
                        </div>
                        <div class="form-check form-switch">
                            <input class="form-check-input" type="checkbox" role="switch" @bind="_prefs.EmailOnWorkspaceInvite" />
                        </div>
                    </div>
                    <div class="profile-row" style="border-bottom:none;">
                        <div></div>
                        <button class="btn btn-primary btn-sm" @onclick="SaveNotificationPreferences" disabled="@_savingPrefs">
                            @if (_savingPrefs) { <span class="spinner-border spinner-border-sm me-1"></span> }
                            Save preferences
                        </button>
                    </div>
                }
            </div>

            <div class="profile-section">
                <h2 class="profile-section-title">Privacy</h2>
                <div class="profile-row">
                    <div>
                        <div class="profile-row-label">Export your data</div>
                        <div class="profile-row-desc">Download a copy of your workspaces and boards</div>
                    </div>
                    <button type="button" class="btn btn-secondary btn-sm" disabled>Export <span class="profile-soon-badge">Soon</span></button>
                </div>
                <div class="profile-row profile-row--danger">
                    <div>
                        <div class="profile-row-label">Delete account</div>
                        <div class="profile-row-desc">Permanently delete your account and all of your data</div>
                    </div>
                    <button type="button" class="btn btn-outline-danger btn-sm" disabled>Delete account <span class="profile-soon-badge">Soon</span></button>
                </div>
            </div>
        </div>
    </Authorized>
</AuthorizeView>

@code {
    [Inject] IJSRuntime JS { get; set; } = null!;
    [Inject] UserService UserService { get; set; } = null!;
    [Inject] AuthService AuthService { get; set; } = null!;
    [Inject] AuthenticationStateProvider AuthStateProvider { get; set; } = null!;
    [Inject] ToastService Toast { get; set; } = null!;

    private NotificationPreferencesDto? _prefs;
    private bool _savingPrefs;

    private string _theme = "light";
    private string _displayName = "";
    private string _email = "";
    private bool _emailConfirmed;

    private bool _savingName;
    private bool? _nameSuccess;
    private string? _nameMessage;

    private bool _sendingVerification;
    private bool? _emailVerifySuccess;
    private string? _emailVerifyMessage;

    private bool _showChangePwd;
    private string _currentPwd = "";
    private string _newPwd = "";
    private string _confirmPwd = "";
    private bool _savingPwd;
    private bool? _pwdSuccess;
    private string? _pwdMessage;

    private bool _showSessions;
    private bool _loadingSessions;
    private bool _savingSessions;
    private bool? _sessionsSuccess;
    private string? _sessionsMessage;
    private List<RefreshSessionDto> _sessions = [];

    // Two-factor authentication
    private bool _twoFaLoading = true;
    private bool _twoFaEnabled;
    private int _recoveryRemaining;
    private bool _twoFaBusy;
    private string? _twoFaError;
    private TwoFactorSetupResponse? _setup;
    private string _enableCode = "";
    private List<string>? _recoveryCodes;
    private bool _showDisable;
    private string _disableCode = "";
    private bool _disableUseRecovery;
    private bool _showRegen;
    private string _regenCode = "";

    protected override async Task OnInitializedAsync()
    {
        _theme = await JS.InvokeAsync<string>("planoraGetTheme");
        var state = await AuthStateProvider.GetAuthenticationStateAsync();
        _displayName = state.User.FindFirst("displayName")?.Value ?? "";
        _email = state.User.FindFirst("email")?.Value ?? "";

        var (profile, _) = await UserService.GetProfileAsync();
        if (profile is not null)
        {
            _displayName = profile.DisplayName;
            _email = profile.Email;
            _emailConfirmed = profile.EmailConfirmed;
        }

        await LoadTwoFactorStatus();

        var (prefs, _) = await UserService.GetNotificationPreferencesAsync();
        _prefs = prefs ?? new NotificationPreferencesDto();
    }

    private async Task SaveNotificationPreferences()
    {
        if (_prefs is null) return;
        _savingPrefs = true;
        var (ok, error) = await UserService.UpdateNotificationPreferencesAsync(_prefs);
        _savingPrefs = false;
        if (ok) Toast.Success("Notification preferences saved.");
        else Toast.Error(error ?? "Could not save preferences.");
    }

    private async Task LoadTwoFactorStatus()
    {
        _twoFaLoading = true;
        var (status, _) = await AuthService.Get2faStatusAsync();
        if (status is not null)
        {
            _twoFaEnabled = status.Enabled;
            _recoveryRemaining = status.RecoveryCodesRemaining;
        }
        _twoFaLoading = false;
    }

    private async Task StartSetup()
    {
        _twoFaBusy = true;
        _twoFaError = null;
        var (setup, error) = await AuthService.Setup2faAsync();
        if (setup is not null)
        {
            _setup = setup;
            _enableCode = "";
        }
        else _twoFaError = error;
        _twoFaBusy = false;
    }

    private void CancelSetup()
    {
        _setup = null;
        _enableCode = "";
        _twoFaError = null;
    }

    private async Task ConfirmEnable()
    {
        if (string.IsNullOrWhiteSpace(_enableCode))
        {
            _twoFaError = "Enter the code from your authenticator app.";
            return;
        }
        _twoFaBusy = true;
        _twoFaError = null;
        var (codes, error) = await AuthService.Enable2faAsync(_enableCode);
        if (codes is not null)
        {
            _recoveryCodes = codes;
            _setup = null;
            _twoFaEnabled = true;
            _recoveryRemaining = codes.Count;
        }
        else _twoFaError = error;
        _twoFaBusy = false;
    }

    private void DismissRecoveryCodes() => _recoveryCodes = null;

    private void ToggleDisable()
    {
        _showDisable = !_showDisable;
        _showRegen = false;
        _disableCode = "";
        _disableUseRecovery = false;
        _twoFaError = null;
    }

    private async Task ConfirmDisable()
    {
        if (string.IsNullOrWhiteSpace(_disableCode))
        {
            _twoFaError = "Enter a code to confirm.";
            return;
        }
        _twoFaBusy = true;
        _twoFaError = null;
        var (ok, error) = await AuthService.Disable2faAsync(_disableCode, _disableUseRecovery);
        if (ok)
        {
            _twoFaEnabled = false;
            _showDisable = false;
            _disableCode = "";
            _recoveryRemaining = 0;
        }
        else _twoFaError = error;
        _twoFaBusy = false;
    }

    private void ToggleRegen()
    {
        _showRegen = !_showRegen;
        _showDisable = false;
        _regenCode = "";
        _twoFaError = null;
    }

    private async Task ConfirmRegen()
    {
        if (string.IsNullOrWhiteSpace(_regenCode))
        {
            _twoFaError = "Enter your current code to confirm.";
            return;
        }
        _twoFaBusy = true;
        _twoFaError = null;
        var (codes, error) = await AuthService.RegenerateRecoveryCodesAsync(_regenCode, false);
        if (codes is not null)
        {
            _recoveryCodes = codes;
            _showRegen = false;
            _regenCode = "";
            _recoveryRemaining = codes.Count;
        }
        else _twoFaError = error;
        _twoFaBusy = false;
    }

    private async Task SetTheme(string theme)
    {
        _theme = theme;
        await JS.InvokeVoidAsync("planoraSetTheme", theme);
    }

    private async Task SaveDisplayName()
    {
        if (string.IsNullOrWhiteSpace(_displayName)) return;
        _savingName = true;
        _nameSuccess = null;
        var (ok, error) = await UserService.UpdateProfileAsync(new UpdateProfileRequest { DisplayName = _displayName.Trim() });
        _nameSuccess = ok;
        _nameMessage = ok ? "Display name updated." : (error ?? "Could not save.");
        _savingName = false;
    }

    private async Task SendEmailConfirmation()
    {
        if (_sendingVerification)
            return;

        _sendingVerification = true;
        _emailVerifySuccess = null;
        _emailVerifyMessage = null;

        var (ok, error) = await AuthService.SendEmailConfirmationAsync();
        _emailVerifySuccess = ok;
        _emailVerifyMessage = ok
            ? "Verification email sent."
            : (error ?? "Could not send verification email.");

        _sendingVerification = false;
    }

    private static string FormatSessionTime(DateTime value) =>
        value.ToLocalTime().ToString("MMM d, HH:mm");

    private async Task ToggleSessions()
    {
        _showSessions = !_showSessions;
        if (_showSessions && _sessions.Count == 0)
            await LoadSessions();
    }

    private async Task LoadSessions(bool clearMessage = true)
    {
        _loadingSessions = true;
        if (clearMessage)
        {
            _sessionsMessage = null;
            _sessionsSuccess = null;
        }

        var (sessions, error) = await AuthService.GetSessionsAsync();
        _sessions = sessions;
        if (error is not null)
        {
            _sessionsSuccess = false;
            _sessionsMessage = error;
        }

        _loadingSessions = false;
    }

    private async Task RevokeSession(Guid sessionId)
    {
        _savingSessions = true;
        _sessionsMessage = null;
        _sessionsSuccess = null;

        var (ok, error) = await AuthService.RevokeSessionAsync(sessionId);
        _sessionsSuccess = ok;
        _sessionsMessage = ok ? "Session revoked." : (error ?? "Could not revoke that session.");
        if (ok)
            await LoadSessions(clearMessage: false);

        _savingSessions = false;
    }

    private async Task RevokeOtherSessions()
    {
        _savingSessions = true;
        _sessionsMessage = null;
        _sessionsSuccess = null;

        var (ok, error) = await AuthService.RevokeOtherSessionsAsync();
        _sessionsSuccess = ok;
        _sessionsMessage = ok ? "Other sessions revoked." : (error ?? "Could not revoke other sessions.");
        if (ok)
            await LoadSessions(clearMessage: false);

        _savingSessions = false;
    }

    private async Task ChangePassword()
    {
        _pwdMessage = null;
        _pwdSuccess = null;

        if (string.IsNullOrWhiteSpace(_currentPwd) || string.IsNullOrWhiteSpace(_newPwd))
        {
            _pwdMessage = "All fields are required.";
            _pwdSuccess = false;
            return;
        }
        if (_newPwd.Length < 6)
        {
            _pwdMessage = "New password must be at least 6 characters.";
            _pwdSuccess = false;
            return;
        }
        if (_newPwd != _confirmPwd)
        {
            _pwdMessage = "Passwords do not match.";
            _pwdSuccess = false;
            return;
        }

        _savingPwd = true;
        var (ok, error) = await UserService.ChangePasswordAsync(new ChangePasswordRequest
        {
            CurrentPassword = _currentPwd,
            NewPassword = _newPwd
        });
        _pwdSuccess = ok;
        _pwdMessage = ok ? "Password changed successfully." : (error ?? "Could not change password.");
        if (ok)
        {
            _currentPwd = "";
            _newPwd = "";
