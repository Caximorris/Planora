@page "/profile"
@attribute [Authorize]
@using Planora.Shared.DTOs.Users

<PageTitle>Profile — Planora</PageTitle>

<AuthorizeView>
    <Authorized>
        <div class="profile-root">
            <div class="profile-header">
                <div class="profile-avatar-lg">
                    @(_displayName.Length > 0 ? _displayName[0].ToString().ToUpper() : "?")
                </div>
                <div>
                    <h1>@(_displayName.Length > 0 ? _displayName : "Account")</h1>
                    <p>@context.User.FindFirst("email")?.Value</p>
                </div>
            </div>

            <div class="profile-section">
                <h2 class="profile-section-title">Account</h2>
                <div class="profile-row">
                    <div>
                        <div class="profile-row-label">Display name</div>
                        <div class="profile-row-desc">The name other members see on your cards and boards</div>
                    </div>
                    <div class="d-flex gap-2 align-items-center">
                        <input class="form-control profile-row-input"
                               @bind="_displayName"
                               maxlength="50"
                               placeholder="Your display name" />
                        <button class="btn btn-primary btn-sm" @onclick="SaveDisplayName" disabled="@_savingName">
                            @if (_savingName) { <span class="spinner-border spinner-border-sm me-1"></span> }
                            Save
                        </button>
                    </div>
                </div>
                @if (_nameSuccess is not null)
                {
                    <div class="alert @(_nameSuccess == true ? "alert-success" : "alert-danger") py-1 mt-1" style="font-size:13px;">
                        @_nameMessage
                    </div>
                }
                <div class="profile-row">
                    <div>
                        <div class="profile-row-label">Email</div>
                        <div class="profile-row-desc">@(_emailConfirmed ? "Verified for account recovery" : "Not verified")</div>
                    </div>
                    <div class="profile-email-actions">
                        <input class="form-control profile-row-input" value="@_email" disabled />
                        @if (_emailConfirmed)
                        {
                            <span class="profile-status-badge profile-status-badge--success">Verified</span>
                        }
                        else
                        {
                            <button type="button" class="btn btn-secondary btn-sm" @onclick="SendEmailConfirmation" disabled="@_sendingVerification">
                                @if (_sendingVerification) { <span class="spinner-border spinner-border-sm me-1"></span> }
                                Send verification
                            </button>
                        }
                    </div>
                </div>
                @if (_emailVerifyMessage is not null)
                {
                    <div class="alert @(_emailVerifySuccess == true ? "alert-success" : "alert-danger") py-1 mt-1" style="font-size:13px;">
                        @_emailVerifyMessage
                    </div>
                }
            </div>

            <div class="profile-section">
                <h2 class="profile-section-title">Appearance</h2>
                <div class="profile-row">
                    <div>
                        <div class="profile-row-label">Theme</div>
                        <div class="profile-row-desc">Choose how Planora looks on your device</div>
                    </div>
                    <div class="profile-theme-options">
                        <button type="button" class="profile-theme-btn @(_theme == "light" ? "profile-theme-btn--active" : "")" @onclick='() => SetTheme("light")'>☀️ Light</button>
                        <button type="button" class="profile-theme-btn @(_theme == "dark" ? "profile-theme-btn--active" : "")" @onclick='() => SetTheme("dark")'>🌙 Dark</button>
                    </div>
                </div>
            </div>

            <div class="profile-section">
                <h2 class="profile-section-title">Security</h2>
                <div class="profile-row">
                    <div>
                        <div class="profile-row-label">Password</div>
                        <div class="profile-row-desc">Change your account password</div>
                    </div>
                    <button type="button" class="btn btn-secondary btn-sm" @onclick="() => _showChangePwd = !_showChangePwd">
                        @(_showChangePwd ? "Cancel" : "Change password")
                    </button>
                </div>

                @if (_showChangePwd)
                {
                    <div class="mt-2 mb-2" style="max-width:380px;">
                        <div class="mb-2">
                            <label class="form-label" style="font-size:13px;">Current password</label>
                            <input type="password" class="form-control form-control-sm" @bind="_currentPwd" />
                        </div>
                        <div class="mb-2">
                            <label class="form-label" style="font-size:13px;">New password</label>
                            <input type="password" class="form-control form-control-sm" @bind="_newPwd" />
                        </div>
                        <div class="mb-3">
                            <label class="form-label" style="font-size:13px;">Confirm new password</label>
                            <input type="password" class="form-control form-control-sm" @bind="_confirmPwd" />
                        </div>
                        @if (_pwdMessage is not null)
                        {
                            <div class="alert @(_pwdSuccess == true ? "alert-success" : "alert-danger") py-1 mb-2" style="font-size:13px;">
                                @_pwdMessage
                            </div>
                        }
                        <button class="btn btn-primary btn-sm" @onclick="ChangePassword" disabled="@_savingPwd">
                            @if (_savingPwd) { <span class="spinner-border spinner-border-sm me-1"></span> }
                            Update password
                        </button>
                    </div>
                }

                <div class="profile-row">
                    <div>
                        <div class="profile-row-label">Two-factor authentication</div>
                        <div class="profile-row-desc">Add an extra layer of security to your account</div>
                    </div>
                    <span class="profile-soon-badge">Soon</span>
                </div>
                <div class="profile-row">
                    <div>
                        <div class="profile-row-label">Active sessions</div>
                        <div class="profile-row-desc">See and manage where you're signed in</div>
                    </div>
                    <button type="button" class="btn btn-secondary btn-sm" @onclick="ToggleSessions">
                        @(_showSessions ? "Hide" : "Manage")
                    </button>
                </div>
                @if (_showSessions)
                {
                    <div class="session-panel">
                        <div class="session-toolbar">
                            <button type="button" class="btn btn-secondary btn-sm" @onclick="() => LoadSessions()" disabled="@_loadingSessions">
                                @if (_loadingSessions) { <span class="spinner-border spinner-border-sm me-1"></span> }
                                Refresh
                            </button>
                            <button type="button" class="btn btn-outline-danger btn-sm" @onclick="RevokeOtherSessions" disabled="@(_savingSessions || !_sessions.Any(s => !s.IsCurrent))">
                                Revoke others
                            </button>
                        </div>
                        @if (_sessionsMessage is not null)
                        {
                            <div class="alert @(_sessionsSuccess == true ? "alert-success" : "alert-danger") py-1 mb-2" style="font-size:13px;">
                                @_sessionsMessage
                            </div>
                        }
                        @if (_loadingSessions)
                        {
                            <div class="session-loading">
                                <span class="spinner-border spinner-border-sm me-2"></span>
                                Loading sessions...
                            </div>
                        }
                        else if (_sessions.Count == 0)
                        {
                            <div class="session-empty">No active sessions found.</div>
                        }
                        else
                        {
                            <div class="session-list">
                                @foreach (var session in _sessions)
                                {
                                    <div class="session-item" @key="session.Id">
                                        <div>
                                            <div class="session-title">
                                                @(session.IsCurrent ? "Current session" : "Signed-in session")
                                            </div>
                                            <div class="session-meta">
                                                Created @FormatSessionTime(session.CreatedAt) · Expires @FormatSessionTime(session.ExpiresAt)
                                            </div>
                                        </div>
                                        @if (session.IsCurrent)
                                        {
                                            <span class="profile-status-badge profile-status-badge--success">Current</span>
                                        }
                                        else
                                        {
                                            <button type="button" class="btn btn-outline-danger btn-sm"
                                                    @onclick="() => RevokeSession(session.Id)"
                                                    disabled="@_savingSessions">
                                                Revoke
                                            </button>
                                        }
                                    </div>
                                }
                            </div>
                        }
                    </div>
                }
            </div>

            <div class="profile-section">
                <h2 class="profile-section-title">Notifications</h2>
                <div class="profile-row">
                    <div>
                        <div class="profile-row-label">Email notifications</div>
                        <div class="profile-row-desc">Get notified about activity on your boards</div>
                    </div>
                    <span class="profile-soon-badge">Soon</span>
                </div>
            </div>

            <div class="profile-section">
                <h2 class="profile-section-title">Privacy</h2>
                <div class="profile-row">
                    <div>
                        <div class="profile-row-label">Export your data</div>
                        <div class="profile-row-desc">Download a copy of your workspaces and boards</div>
                    </div>
                    <button type="button" class="btn btn-secondary btn-sm" disabled>Export <span class="profile-soon-badge">Soon</span></button>
                </div>
                <div class="profile-row profile-row--danger">
                    <div>
                        <div class="profile-row-label">Delete account</div>
                        <div class="profile-row-desc">Permanently delete your account and all of your data</div>
                    </div>
                    <button type="button" class="btn btn-outline-danger btn-sm" disabled>Delete account <span class="profile-soon-badge">Soon</span></button>
                </div>
            </div>
        </div>
    </Authorized>
</AuthorizeView>

@code {
    [Inject] IJSRuntime JS { get; set; } = null!;
    [Inject] UserService UserService { get; set; } = null!;
    [Inject] AuthService AuthService { get; set; } = null!;
    [Inject] AuthenticationStateProvider AuthStateProvider { get; set; } = null!;

    private string _theme = "light";
    private string _displayName = "";
    private string _email = "";
    private bool _emailConfirmed;

    private bool _savingName;
    private bool? _nameSuccess;
    private string? _nameMessage;

    private bool _sendingVerification;
    private bool? _emailVerifySuccess;
    private string? _emailVerifyMessage;

    private bool _showChangePwd;
    private string _currentPwd = "";
    private string _newPwd = "";
    private string _confirmPwd = "";
    private bool _savingPwd;
    private bool? _pwdSuccess;
    private string? _pwdMessage;

    private bool _showSessions;
    private bool _loadingSessions;
    private bool _savingSessions;
    private bool? _sessionsSuccess;
    private string? _sessionsMessage;
    private List<RefreshSessionDto> _sessions = [];

    protected override async Task OnInitializedAsync()
    {
        _theme = await JS.InvokeAsync<string>("planoraGetTheme");
        var state = await AuthStateProvider.GetAuthenticationStateAsync();
        _displayName = state.User.FindFirst("displayName")?.Value ?? "";
        _email = state.User.FindFirst("email")?.Value ?? "";

        var (profile, _) = await UserService.GetProfileAsync();
        if (profile is not null)
        {
            _displayName = profile.DisplayName;
            _email = profile.Email;
            _emailConfirmed = profile.EmailConfirmed;
        }
    }

    private async Task SetTheme(string theme)
    {
        _theme = theme;
        await JS.InvokeVoidAsync("planoraSetTheme", theme);
    }

    private async Task SaveDisplayName()
    {
        if (string.IsNullOrWhiteSpace(_displayName)) return;
        _savingName = true;
        _nameSuccess = null;
        var (ok, error) = await UserService.UpdateProfileAsync(new UpdateProfileRequest { DisplayName = _displayName.Trim() });
        _nameSuccess = ok;
        _nameMessage = ok ? "Display name updated." : (error ?? "Could not save.");
        _savingName = false;
    }

    private async Task SendEmailConfirmation()
    {
        if (_sendingVerification)
            return;

        _sendingVerification = true;
        _emailVerifySuccess = null;
        _emailVerifyMessage = null;

        var (ok, error) = await AuthService.SendEmailConfirmationAsync();
        _emailVerifySuccess = ok;
        _emailVerifyMessage = ok
            ? "Verification email sent."
            : (error ?? "Could not send verification email.");

        _sendingVerification = false;
    }

    private static string FormatSessionTime(DateTime value) =>
        value.ToLocalTime().ToString("MMM d, HH:mm");

    private async Task ToggleSessions()
    {
        _showSessions = !_showSessions;
        if (_showSessions && _sessions.Count == 0)
            await LoadSessions();
    }

    private async Task LoadSessions(bool clearMessage = true)
    {
        _loadingSessions = true;
        if (clearMessage)
        {
            _sessionsMessage = null;
            _sessionsSuccess = null;
        }

        var (sessions, error) = await AuthService.GetSessionsAsync();
        _sessions = sessions;
        if (error is not null)
        {
            _sessionsSuccess = false;
            _sessionsMessage = error;
        }

        _loadingSessions = false;
    }

    private async Task RevokeSession(Guid sessionId)
    {
        _savingSessions = true;
        _sessionsMessage = null;
        _sessionsSuccess = null;

        var (ok, error) = await AuthService.RevokeSessionAsync(sessionId);
        _sessionsSuccess = ok;
        _sessionsMessage = ok ? "Session revoked." : (error ?? "Could not revoke that session.");
        if (ok)
            await LoadSessions(clearMessage: false);

        _savingSessions = false;
    }

    private async Task RevokeOtherSessions()
    {
        _savingSessions = true;
        _sessionsMessage = null;
        _sessionsSuccess = null;

        var (ok, error) = await AuthService.RevokeOtherSessionsAsync();
        _sessionsSuccess = ok;
        _sessionsMessage = ok ? "Other sessions revoked." : (error ?? "Could not revoke other sessions.");
        if (ok)
            await LoadSessions(clearMessage: false);

        _savingSessions = false;
    }

    private async Task ChangePassword()
    {
        _pwdMessage = null;
        _pwdSuccess = null;

        if (string.IsNullOrWhiteSpace(_currentPwd) || string.IsNullOrWhiteSpace(_newPwd))
        {
            _pwdMessage = "All fields are required.";
            _pwdSuccess = false;
            return;
        }
        if (_newPwd.Length < 6)
        {
            _pwdMessage = "New password must be at least 6 characters.";
            _pwdSuccess = false;
            return;
        }
        if (_newPwd != _confirmPwd)
        {
            _pwdMessage = "Passwords do not match.";
            _pwdSuccess = false;
            return;
        }

        _savingPwd = true;
        var (ok, error) = await UserService.ChangePasswordAsync(new ChangePasswordRequest
        {
            CurrentPassword = _currentPwd,
            NewPassword = _newPwd
        });
        _pwdSuccess = ok;
        _pwdMessage = ok ? "Password changed successfully." : (error ?? "Could not change password.");
        if (ok)
        {
            _currentPwd = "";
            _newPwd = "";
            _confirmPwd = "";
            _showChangePwd = false;
        }
        _savingPwd = false;
    }
}
