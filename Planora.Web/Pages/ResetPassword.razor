@page "/reset-password"
@layout PublicLayout
@using System.Web
@using Planora.Shared.DTOs.Auth

<PageTitle>Choose a new password — Planora</PageTitle>

<div class="auth-page">
    <div class="auth-card">
        <a class="auth-logo" href="/">Planora</a>
        <h1 class="auth-title">Choose a new password</h1>

        @if (_done)
        {
            <div class="alert alert-success py-2">
                Your password has been reset. You can now sign in.
            </div>
            <a class="btn btn-primary w-100" href="/login">Go to sign in</a>
        }
        else if (!_hasToken)
        {
            <div class="alert alert-danger py-2">
                This reset link is invalid or incomplete. Please request a new one.
            </div>
            <p class="auth-switch"><a href="/forgot-password">Request a new link</a></p>
        }
        else
        {
            @if (_error is not null)
            {
                <div class="alert alert-danger py-2">@_error</div>
            }

            <div class="mb-3">
                <label class="form-label">New password</label>
                <input type="password" class="form-control" @bind="_password" @bind:event="oninput"
                       placeholder="At least 8 characters" @onkeydown="OnKeyDown" />
            </div>
            <div class="mb-3">
                <label class="form-label">Confirm new password</label>
                <input type="password" class="form-control" @bind="_confirmPassword" @bind:event="oninput"
                       placeholder="Re-enter password" @onkeydown="OnKeyDown" />
            </div>
            <button class="btn btn-primary w-100" @onclick="HandleSubmit" disabled="@_loading">
                @if (_loading) { <span class="spinner-border spinner-border-sm me-2"></span> }
                Reset password
            </button>

            <p class="auth-switch"><a href="/login">Back to sign in</a></p>
        }
    </div>
</div>

@code {
    [Inject] AuthService AuthService { get; set; } = null!;
    [Inject] NavigationManager Nav { get; set; } = null!;

    private string _email = "";
    private string _token = "";
    private string _password = "";
    private string _confirmPassword = "";
    private string? _error;
    private bool _loading;
    private bool _done;
    private bool _hasToken;

    protected override void OnInitialized()
    {
        var query = HttpUtility.ParseQueryString(new Uri(Nav.Uri).Query);
        _email = query["email"] ?? "";
        _token = query["token"] ?? "";
        _hasToken = !string.IsNullOrWhiteSpace(_email) && !string.IsNullOrWhiteSpace(_token);
    }

    private async Task HandleSubmit()
    {
        if (_loading)
            return;

        if (string.IsNullOrWhiteSpace(_password) || _password.Length < 8)
        {
            _error = "Password must be at least 8 characters.";
            return;
        }

        if (_password != _confirmPassword)
        {
            _error = "Passwords do not match.";
            return;
        }

        _loading = true;
        _error = null;
        var (success, error) = await AuthService.ResetPasswordAsync(
            new() { Email = _email, Token = _token, NewPassword = _password });
        _loading = false;
        if (success) _done = true;
        else _error = error;
    }

    private async Task OnKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
            await HandleSubmit();
    }
}
