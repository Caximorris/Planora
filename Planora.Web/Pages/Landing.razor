@page "/"
@inject NavigationManager Nav
@inject AuthService Auth

<PageTitle>Planora — Organize your work, your way</PageTitle>

@if (_ready)
{
    <div class="landing-root">

        <nav class="landing-nav">
            <span class="landing-brand">
                <svg viewBox="0 0 22 18" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true" width="20" height="16">
                    <rect x="0"  y="2" width="6" height="14" rx="1.5" fill="currentColor"/>
                    <rect x="8"  y="2" width="6" height="9"  rx="1.5" fill="currentColor" opacity=".75"/>
                    <rect x="16" y="2" width="6" height="11" rx="1.5" fill="currentColor" opacity=".55"/>
                </svg>
                Planora
            </span>
            <a class="landing-nav-signin" href="/login">Sign in →</a>
        </nav>

        <!-- ── Primary hero: instant demo ──────────────────────── -->
        <section class="landing-hero">
            <h1 class="landing-title">
                Organize your work,<br>your way.
            </h1>
            <p class="landing-subtitle">
                Visual Kanban for individuals and teams — try it in one click.
            </p>

            <button class="landing-demo-btn" @onclick="TryDemoAsync" disabled="@_loading">
                @if (_loading)
                {
                    <span class="landing-spinner" aria-hidden="true"></span>
                    <span>@_loadingMessage</span>
                }
                else
                {
                    <span>▶&nbsp; Try it instantly</span>
                }
            </button>

            <p class="landing-demo-hint">No sign-up needed — a demo account is created for you.</p>

            @if (_error is not null)
            {
                <p class="landing-error">@_error</p>
            }

            <div class="landing-divider">
                <span>or</span>
            </div>

            <div class="landing-secondary-links">
                <a class="landing-link-register" href="/register">Create your own account</a>
                <span class="landing-dot">·</span>
                <a class="landing-link-signin" href="/login">Sign in</a>
            </div>
        </section>

        <!-- ── Secondary: feature details ─────────────────────── -->
        <section class="landing-details">
            <div class="landing-badge">Free &middot; No credit card &middot; No real data needed</div>
            <ul class="landing-features">
                <li>
                    <span class="landing-check">✓</span>
                    <span>A full demo workspace with a sample board is created for you instantly</span>
                </li>
                <li>
                    <span class="landing-check">✓</span>
                    <span>Drag &amp; drop cards, reorder columns, filter by priority — everything works</span>
                </li>
                <li>
                    <span class="landing-check">✓</span>
                    <span>Use any email to sign up — invented addresses work fine</span>
                </li>
            </ul>
        </section>

    </div>
}

@code {
    [CascadingParameter] private Task<AuthenticationState> AuthState { get; set; } = null!;
    private bool _ready;
    private bool _loading;
    private string? _error;
    private string _loadingMessage = "Setting up your workspace…";

    protected override async Task OnInitializedAsync()
    {
        var state = await AuthState;
        if (state.User.Identity?.IsAuthenticated == true)
            Nav.NavigateTo("/home", replace: true);
        else
            _ready = true;
    }

    private async Task TryDemoAsync()
    {
        _loading = true;
        _error = null;
        _loadingMessage = "Setting up your workspace…";

        // After 4s with no response, hint that the server may be cold-starting
        var cts = new CancellationTokenSource();
        _ = Task.Delay(4000, cts.Token).ContinueWith(t =>
        {
            if (t.IsCompletedSuccessfully && _loading)
            {
                _loadingMessage = "Server is waking up — almost there…";
                InvokeAsync(StateHasChanged);
            }
        });

        var (success, error) = await Auth.DemoLoginAsync();
        cts.Cancel();
        cts.Dispose();

        if (success)
            Nav.NavigateTo("/workspaces", replace: true);
        else
        {
            _error = error;
            _loading = false;
        }
    }
}
