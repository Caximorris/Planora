@page "/boards/{Id:guid}"
@attribute [Authorize]
@implements IDisposable
@using Planora.Shared.DTOs.Checklist
@using Planora.Shared.DTOs.Label
@using Planora.Shared.Constants
@using Planora.Shared.Enums

<PageTitle>@(_board?.Name ?? "Board") — Planora</PageTitle>

@if (_loading)
{
    <div class="board-loading"><span class="spinner-border text-light"></span></div>
}
else if (_board is null)
{
    <div class="container py-5 text-center">
        <p class="text-muted">Board not found.</p>
        <a href="/workspaces" class="btn btn-primary mt-2">Back to workspaces</a>
    </div>
}
else
{
    <div class="board-root" style="@BoardBackgroundStyle">
        <div class="board-header">
            <div class="board-breadcrumb">
                <a href="/workspaces">Workspaces</a>
                <span>/</span>
                <span>@(_workspaceName ?? "...")</span>
                <span>/</span>
            </div>
            <div class="board-title-wrap">
                <span class="board-title-display">@_board.Name</span>
                <button type="button" class="board-header-action" @onclick="OpenActivity">Activity</button>
                <button type="button" class="settings-gear-btn" title="Board settings" aria-label="Board settings" @onclick="() => _showBoardSettings = true">⚙️</button>
            </div>
            <div class="board-filter">
                <span class="board-filter-label">Filter:</span>
                <button class="filter-pill @(_filter == null ? "active" : "")" aria-pressed="@(_filter == null)" @onclick="() => _filter = null">All</button>
                <button class="filter-pill @(_filter == CardPriority.Low ? "active" : "")" aria-pressed="@(_filter == CardPriority.Low)" @onclick="() => _filter = CardPriority.Low">Low</button>
                <button class="filter-pill @(_filter == CardPriority.Medium ? "active" : "")" aria-pressed="@(_filter == CardPriority.Medium)" @onclick="() => _filter = CardPriority.Medium">Medium</button>
                <button class="filter-pill @(_filter == CardPriority.High ? "active" : "")" aria-pressed="@(_filter == CardPriority.High)" @onclick="() => _filter = CardPriority.High">High</button>
                <button class="filter-pill @(_filter == CardPriority.Critical ? "active" : "")" aria-pressed="@(_filter == CardPriority.Critical)" @onclick="() => _filter = CardPriority.Critical">Critical</button>
            </div>
        </div>

        <div class="board-columns">
            <CascadingValue Value="_membersByUserId" Name="BoardMembers">
            @foreach (var col in _board.Columns.OrderBy(c => c.Position))
            {
                <KanbanColumn @key="col.Id"
                    Column="col"
                    Filter="_filter"
                    OnAddCard="@(title => AddCard(col.Id, title))"
                    OnDeleteColumn="@(() => DeleteColumn(col.Id))"
                    OnCardClick="@(card => OpenCard(card))"
                    OnColorChange="@(color => ChangeColumnColor(col.Id, color))"
                    OnRename="@(title => RenameColumn(col.Id, title))" />
            }

            </CascadingValue>
            <div class="add-column-panel">
                @if (_addingColumn)
                {
                    <div class="new-column-form">
                        <input class="form-control mb-2"
                               @bind="_newColTitle"
                               placeholder="Column title"
                               @onkeydown="ColKeyDown" />
                        <div class="d-flex gap-2">
                            <button class="btn btn-sm btn-primary" @onclick="AddColumn">Add</button>
                            <button class="btn btn-sm btn-secondary" @onclick="CancelColumn">Cancel</button>
                        </div>
                    </div>
                }
                else
                {
                    <button class="add-column-btn" @onclick="() => _addingColumn = true">+ Add column</button>
                }
            </div>
        </div>
    </div>
}

@* Card detail modal *@
@if (_editCard is not null)
{
    <div class="modal-backdrop fade show" @onclick="CloseCard"></div>
    <div class="modal fade show d-block" tabindex="-1" role="dialog" aria-modal="true" aria-labelledby="card-detail-title">
        <div class="modal-dialog modal-dialog-centered modal-lg">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="card-detail-title">@_editTitle</h5>
                    <button class="btn-close" aria-label="Close card details" @onclick="CloseCard"></button>
                </div>
                <div class="modal-body">
                    @if (_editCard is not null && _editCard.IsArchived)
                    {
                        <div class="alert alert-warning py-2 mb-3" style="font-size:13px;">
                            This card is archived. It is hidden from the board but can be restored.
                        </div>
                    }
                    <div class="mb-3">
                        <label class="form-label">Title</label>
                        <input class="form-control" @bind="_editTitle" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Description</label>
                        <textarea class="form-control" rows="4" @bind="_editDesc" placeholder="Add a description…"></textarea>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Assignee</label>
                        <select class="form-select" @bind="_editAssigneeId">
                            <option value="">— Unassigned —</option>
                            @foreach (var member in _membersByUserId.Values)
                            {
                                <option value="@member.UserId">@member.DisplayName</option>
                            }
                        </select>
                    </div>
                    <div class="row g-2">
                        <div class="col-6">
                            <label class="form-label">Due date</label>
                            <input type="date" class="form-control" @bind="_editDue" />
                        </div>
                        <div class="col-6">
                            <label class="form-label">Priority</label>
                            <select class="form-select" @bind="_editPriority">
                                @foreach (var p in Enum.GetValues<CardPriority>())
                                {
                                    <option value="@p">@p</option>
                                }
                            </select>
                        </div>
                    </div>
                    <div class="mb-3 mt-3">
                        <label class="form-label">Color</label>
                        <div class="color-swatch-grid" role="radiogroup" aria-label="Card color">
                            @foreach (var color in PlanoraColors.SurfaceBackgroundColors)
                            {
                                <button type="button"
                                        class="color-swatch @(IsSelectedSurfaceColor(_editColor, color) ? "color-swatch--selected" : "")"
                                        style="@SwatchStyle(color)"
                                        title="@color"
                                        aria-label="Use card color @color"
                                        aria-pressed="@IsSelectedSurfaceColor(_editColor, color)"
                                        @onclick="() => _editColor = color"></button>
                            }
                        </div>
                        <div class="mt-2">
                            <button type="button" class="btn btn-sm btn-secondary" @onclick="() => _editColor = null">Reset</button>
                        </div>
                    </div>
                    <div class="mb-3 mt-3">
                        <div class="d-flex align-items-center justify-content-between mb-2">
                            <label class="form-label mb-0">Attachments</label>
                            <label class="settings-upload-label attachment-upload-label">
                                @(_uploadingAttachment ? "Uploading..." : "Upload...")
                                <InputFile OnChange="OnAttachmentSelected" accept="image/png,image/jpeg,image/webp,image/gif,application/pdf,text/plain" disabled="@_uploadingAttachment" />
                            </label>
                        </div>
                        @if (_attachmentError is not null)
                        {
                            <div class="settings-error mb-2">@_attachmentError</div>
                        }
                        @if (_editCard!.Attachments.Count == 0)
                        {
                            <p class="attachments-empty">No attachments.</p>
                        }
                        else
                        {
                            <div class="attachments-list">
                                @foreach (var attachment in _editCard.Attachments.OrderBy(a => a.CreatedAt))
                                {
                                    <div class="attachment-row" @key="attachment.Id">
                                        <a class="attachment-link"
                                           href="@CardService.ResolveAttachmentUrl(attachment.Url)"
                                           target="_blank"
                                           rel="noopener">
                                            @attachment.FileName
                                        </a>
                                        <span class="attachment-size">@FormatFileSize(attachment.SizeBytes)</span>
                                        <button type="button" class="btn-icon-sm" aria-label="Delete attachment @attachment.FileName" @onclick="() => DeleteAttachment(attachment)">✕</button>
                                    </div>
                                }
                            </div>
                        }
                    </div>
                    @* Labels *@
                    <div class="mb-3 mt-3">
                        <div class="d-flex align-items-center justify-content-between mb-2">
                            <label class="form-label mb-0">Labels</label>
                            <button type="button" class="btn btn-link btn-sm p-0"
                                    @onclick="() => _showLabelManager = !_showLabelManager">
                                @(_showLabelManager ? "Done" : "Manage")
                            </button>
                        </div>
                        <div class="label-picker">
                            @foreach (var label in _workspaceLabels)
                            {
                                var isActive = _editCardLabelIds.Contains(label.Id);
                                <button type="button"
                                        class="label-chip @(isActive ? "label-chip--active" : "")"
                                        style="@LabelChipStyle(label.Color)"
                                        title="@label.Name"
                                        @onclick="() => ToggleLabel(label)">
                                    @label.Name
                                    @if (isActive) { <span class="label-check">✓</span> }
                                </button>
                            }
                        </div>
                        @if (_showLabelManager)
                        {
                            <div class="label-manager mt-2">
                                <div class="label-swatch-row mb-2" role="radiogroup" aria-label="Label color">
                                    @foreach (var color in PlanoraColors.LabelBackgroundColors)
                                    {
                                        <button type="button"
                                                class="color-swatch color-swatch--sm @(IsSelectedHex(_newLabelColor, color) ? "color-swatch--selected" : "")"
                                                style="@SwatchStyle(color)"
                                                title="@color"
                                                aria-label="Use label color @color"
                                                aria-pressed="@IsSelectedHex(_newLabelColor, color)"
                                                @onclick="() => _newLabelColor = color"></button>
                                    }
                                </div>
                                <div class="d-flex gap-2 align-items-center">
                                    <input class="form-control form-control-sm"
                                           placeholder="Label name…"
                                           @bind="_newLabelName"
                                           @onkeydown="@(e => { if (e.Key == "Enter") _ = CreateWorkspaceLabel(); })" />
                                    <button type="button" class="btn btn-sm btn-primary"
                                            @onclick="CreateWorkspaceLabel"
                                            disabled="@string.IsNullOrWhiteSpace(_newLabelName)">Add</button>
                                </div>
                                @if (_workspaceLabels.Count > 0)
                                {
                                    <div class="label-manager-list mt-2">
                                        @foreach (var label in _workspaceLabels)
                                        {
                                            <div class="label-manager-row">
                                                <span class="label-manager-color" style="@SwatchStyle(label.Color)"></span>
                                                <span class="label-manager-name">@label.Name</span>
                                                <button type="button" class="btn-icon-sm" aria-label="Delete label @label.Name" @onclick="() => DeleteWorkspaceLabel(label)">✕</button>
                                            </div>
                                        }
                                    </div>
                                }
                            </div>
                        }
                    </div>

                    @* Checklists *@
                    @if (_editChecklists.Count > 0 || _addingChecklist)
                    {
                        <div class="checklists-section mb-3">
                            <label class="form-label">Checklists</label>
                            @foreach (var cl in _editChecklists)
                            {
                                var total = cl.Items.Count;
                                var done = cl.Items.Count(i => i.IsCompleted);
                                var pct = total == 0 ? 0 : (int)(done * 100.0 / total);
                                <div class="checklist-block" @key="cl.Id">
                                    <div class="checklist-header">
                                        <span class="checklist-title">@cl.Title</span>
                                        <span class="checklist-progress-label">@done/@total</span>
                                        <button type="button" class="btn-icon-sm ms-auto" aria-label="Delete checklist @cl.Title" @onclick="() => DeleteChecklist(cl)">✕</button>
                                    </div>
                                    <div class="checklist-progress-bar mb-2">
                                        <div class="checklist-progress-fill @(pct == 100 ? "checklist-progress-fill--done" : "")"
                                             style="width:@(pct)%"></div>
                                    </div>
                                    <div class="checklist-items">
                                        @foreach (var item in cl.Items.OrderBy(i => i.Position))
                                        {
                                            <div class="checklist-item @(item.IsCompleted ? "checklist-item--done" : "")" @key="item.Id">
                                                <input type="checkbox" class="checklist-checkbox"
                                                       checked="@item.IsCompleted"
                                                       @onchange="() => ToggleChecklistItem(cl, item)" />
                                                <span class="checklist-item-text">@item.Text</span>
                                                <button type="button" class="btn-icon-sm" aria-label="Delete checklist item @item.Text" @onclick="() => DeleteChecklistItem(cl, item)">✕</button>
                                            </div>
                                        }
                                    </div>
                                    <div class="checklist-add-item mt-1">
                                        <input class="form-control form-control-sm"
                                               placeholder="Add an item…"
                                               value="@(_newItemText.GetValueOrDefault(cl.Id, string.Empty))"
                                               @oninput="e => SetNewItemText(cl.Id, e.Value?.ToString())"
                                               @onkeydown="e => OnAddItemKeyDown(e, cl)" />
                                    </div>
                                </div>
                            }
                        </div>
                    }
                    <div class="mb-3">
                        @if (_addingChecklist)
                        {
                            <div class="d-flex gap-2 align-items-center">
                                <input class="form-control form-control-sm"
                                       placeholder="Checklist title…"
                                       @bind="_newChecklistTitle"
                                       @onkeydown="OnChecklistTitleKeyDown" />
                                <button type="button" class="btn btn-sm btn-primary" @onclick="AddChecklist">Add</button>
                                <button type="button" class="btn btn-sm btn-secondary" @onclick="CancelAddChecklist">Cancel</button>
                            </div>
                        }
                        else
                        {
                            <button type="button" class="btn btn-sm btn-outline-secondary" @onclick="() => _addingChecklist = true">+ Add checklist</button>
                        }
                    </div>

                    <hr class="mt-3 mb-3" />
                    <div class="comments-section">
                        <h6 class="comments-title">Comments</h6>
                        @if (_loadingComments)
                        {
                            <div class="text-center py-2"><span class="spinner-border spinner-border-sm"></span></div>
                        }
                        else if (_comments.Count == 0)
                        {
                            <p class="comments-empty">No comments yet. Be the first!</p>
                        }
                        else
                        {
                            <div class="comments-list">
                                @foreach (var comment in _comments)
                                {
                                    <div class="comment-item" @key="comment.Id">
                                        <div class="comment-avatar">@comment.AuthorDisplayName[0]</div>
                                        <div class="comment-body">
                                            <div class="comment-header">
                                                <span class="comment-author">@comment.AuthorDisplayName</span>
                                                <span class="comment-time">@TimeAgo(comment.CreatedAt)</span>
                                                @if (comment.AuthorId == _currentUserId)
                                                {
                                                    <button class="comment-delete-btn" aria-label="Delete comment" @onclick="() => DeleteComment(comment)">✕</button>
                                                }
                                            </div>
                                            <div class="comment-text">@comment.Text</div>
                                        </div>
                                    </div>
                                }
                            </div>
                        }
                        <div class="comment-input-row mt-3">
                            <textarea class="form-control form-control-sm"
                                      rows="2"
                                      placeholder="Write a comment…"
                                      @bind="_newCommentText"
                                      @onkeydown="CommentKeyDown"></textarea>
                            <button class="btn btn-sm btn-primary mt-1 align-self-end"
                                    @onclick="AddComment"
                                    disabled="@(_savingComment || string.IsNullOrWhiteSpace(_newCommentText))">
                                Post
                            </button>
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button class="btn btn-outline-danger btn-sm me-auto" @onclick="DeleteCard">Delete card</button>
                    @if (_editCard is not null && !_editCard.IsArchived)
                    {
                        <button class="btn btn-outline-secondary btn-sm" @onclick="ArchiveCard" disabled="@_saving">Archive</button>
                    }
                    else if (_editCard is not null && _editCard.IsArchived)
                    {
                        <button class="btn btn-outline-secondary btn-sm" @onclick="UnarchiveCard" disabled="@_saving">Restore</button>
                    }
                    <button class="btn btn-secondary btn-sm" @onclick="CloseCard">Cancel</button>
                    <button class="btn btn-primary btn-sm" @onclick="SaveCard" disabled="@_saving">Save</button>
                </div>
            </div>
        </div>
    </div>
}

@* Activity modal *@
@if (_showActivity)
{
    <div class="modal-backdrop fade show" @onclick="CloseActivity"></div>
    <div class="modal fade show d-block" tabindex="-1" role="dialog" aria-modal="true" aria-labelledby="board-activity-title">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="board-activity-title">Board activity</h5>
                    <button class="btn-close" aria-label="Close board activity" @onclick="CloseActivity"></button>
                </div>
                <div class="modal-body">
                    @if (_loadingActivity)
                    {
                        <div class="text-center py-3">
                            <span class="spinner-border spinner-border-sm me-2"></span>
                            Loading activity...
                        </div>
                    }
                    else if (_activityError is not null)
                    {
                        <div class="alert alert-danger py-2">@_activityError</div>
                    }
                    else if (_activity.Count == 0)
                    {
                        <p class="activity-empty">No activity yet.</p>
                    }
                    else
                    {
                        <div class="activity-list">
                            @foreach (var item in _activity)
                            {
                                <div class="activity-item" @key="item.Id">
                                    <div class="activity-dot" aria-hidden="true"></div>
                                    <div class="activity-copy">
                                        <div class="activity-summary">@item.Summary</div>
                                        <div class="activity-meta">@item.ActorDisplayName · @FormatActivityTime(item.CreatedAt)</div>
                                    </div>
                                </div>
                            }
                        </div>
                    }
                </div>
                <div class="modal-footer">
                    <button class="btn btn-secondary btn-sm" @onclick="CloseActivity">Close</button>
                </div>
            </div>
        </div>
    </div>
}

@* Board settings *@
@if (_showBoardSettings)
{
    <div class="modal-backdrop fade show" @onclick="CloseBoardSettings"></div>
    <div class="modal fade show d-block" tabindex="-1" role="dialog" aria-modal="true" aria-labelledby="board-settings-title">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="board-settings-title">Board settings</h5>
                    <button class="btn-close" aria-label="Close board settings" @onclick="CloseBoardSettings"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label">Name</label>
                        <input class="form-control" value="@_board!.Name" @onchange="SaveBoardName" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Color</label>
                        <div class="color-swatch-grid" role="radiogroup" aria-label="Board color">
                            @foreach (var color in PlanoraColors.BoardBackgroundColors)
                            {
                                <button type="button"
                                        class="color-swatch color-swatch--board @(IsSelectedBoardColor(color) ? "color-swatch--selected" : "")"
                                        style="@SwatchStyle(color)"
                                        title="@color"
                                        aria-label="Use board color @color"
                                        aria-pressed="@IsSelectedBoardColor(color)"
                                        @onclick="() => SaveBoardColor(color)"></button>
                            }
                        </div>
                    </div>
                    @if (_showArchivedCards)
                    {
                        <div class="mb-3">
                            <label class="form-label">Archived cards</label>
                            @if (_loadingArchivedCards)
                            {
                                <div class="text-center py-2"><span class="spinner-border spinner-border-sm"></span></div>
                            }
                            else if (_archivedCards.Count == 0)
                            {
                                <p style="font-size:13px;color:var(--color-text-mid)">No archived cards.</p>
                            }
                            else
                            {
                                <div class="archived-cards-list">
                                    @foreach (var card in _archivedCards)
                                    {
                                        <div class="archived-card-row" @key="card.Id">
                                            <span class="archived-card-title">@card.Title</span>
                                            <div class="d-flex gap-1">
                                                <button class="btn btn-sm btn-outline-secondary" @onclick="() => RestoreArchivedCard(card)">Restore</button>
                                                <button class="btn btn-sm btn-outline-danger" @onclick="() => DeleteArchivedCard(card)">Delete</button>
                                            </div>
                                        </div>
                                    }
                                </div>
                            }
                        </div>
                    }
                    @if (_showTrashCards)
                    {
                        <div class="mb-3">
                            <label class="form-label">🗑 Trash</label>
                            @if (_loadingTrashCards)
                            {
                                <div class="text-center py-2"><span class="spinner-border spinner-border-sm"></span></div>
                            }
                            else if (_trashedCards.Count == 0)
                            {
                                <p style="font-size:13px;color:var(--color-text-mid)">Trash is empty.</p>
                            }
                            else
                            {
                                <div class="archived-cards-list">
                                    @foreach (var card in _trashedCards)
                                    {
                                        <div class="archived-card-row" @key="card.Id">
                                            <span class="archived-card-title">@card.Title</span>
                                            <div class="d-flex gap-1">
                                                <button class="btn btn-sm btn-outline-secondary" @onclick="() => RestoreTrashedCard(card)">Restore</button>
                                                <button class="btn btn-sm btn-outline-danger" @onclick="() => PermanentDeleteCard(card)">Delete forever</button>
                                            </div>
                                        </div>
                                    }
                                </div>
                            }
                        </div>
                    }
                    <div class="mb-3">
                        <label class="form-label">Cover image</label>
                        <div class="d-flex align-items-center gap-2">
                            <label class="settings-upload-label">
                                @(_board.CoverImageUrl is null ? "Upload…" : "Change…")
                                <InputFile OnChange="OnCoverFileSelected" accept="image/png,image/jpeg,image/webp,image/gif" />
                            </label>
                            @if (_board.CoverImageUrl is not null)
                            {
                                <button type="button" class="btn btn-sm btn-outline-secondary" @onclick="RemoveCoverImage">Remove</button>
                            }
                        </div>
                        @if (_coverError is not null)
                        {
                            <div class="settings-error mt-1">@_coverError</div>
                        }
                    </div>
                </div>
                <div class="modal-footer">
                    <button class="btn btn-outline-danger btn-sm me-auto" @onclick="ConfirmDeleteBoard">Delete board</button>
                    <button class="btn btn-outline-secondary btn-sm" @onclick="ToggleArchivedCards">
                        @(_showArchivedCards ? "Hide archived" : "View archived cards")
                    </button>
                    <button class="btn btn-outline-secondary btn-sm" @onclick="ToggleTrashCards">
                        @(_showTrashCards ? "Hide trash" : "🗑 Trash")
                    </button>
                    <button class="btn btn-secondary btn-sm" @onclick="CloseBoardSettings">Close</button>
                </div>
            </div>
        </div>
    </div>
}

@* Delete board confirmation *@
@if (_confirmDeleteBoard)
{
    <div class="modal-backdrop fade show"></div>
    <div class="modal fade show d-block" tabindex="-1" role="dialog" aria-modal="true" aria-labelledby="delete-board-title">
        <div class="modal-dialog modal-dialog-centered modal-sm">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="delete-board-title">Delete board?</h5>
                    <button class="btn-close" aria-label="Close delete board dialog" @onclick="() => _confirmDeleteBoard = false"></button>
                </div>
                <div class="modal-body">
                    <p style="font-size:13px;color:var(--color-text-mid);">
                        "<strong>@_board?.Name</strong>" and all its columns and cards will be permanently deleted.
                    </p>
                </div>
                <div class="modal-footer">
                    <button class="btn btn-secondary btn-sm" @onclick="() => _confirmDeleteBoard = false">Cancel</button>
                    <button class="btn btn-danger btn-sm" @onclick="DeleteBoard" disabled="@_saving">Delete</button>
                </div>
            </div>
        </div>
    </div>
}

@if (_showCropModal)
{
    <div class="modal-backdrop fade show"></div>
    <div class="modal d-block" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered modal-lg">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Position your cover</h5>
                    <button type="button" class="btn-close" @onclick="CloseCrop" disabled="@_saving"></button>
                </div>
                <div class="modal-body">
                    <p style="font-size:13px;color:var(--color-text-mid);margin-bottom:8px;">
                        Drag the image to reposition, and use the slider to zoom.
                    </p>
                    <div class="cover-crop-stage">
                        <img @ref="_cropImg" alt="Cover to crop" />
                    </div>
                    <div class="d-flex align-items-center gap-2 mt-3">
                        <span aria-hidden="true">🔍</span>
                        <input type="range" class="form-range" min="0" max="100" step="1"
                               value="@_cropZoom" @oninput="OnCropZoom" aria-label="Zoom" />
                    </div>
                </div>
                <div class="modal-footer">
                    <button class="btn btn-secondary btn-sm" @onclick="CloseCrop" disabled="@_saving">Cancel</button>
                    <button class="btn btn-primary btn-sm" @onclick="SaveCrop" disabled="@_saving">Save cover</button>
                </div>
            </div>
        </div>
    </div>
}

