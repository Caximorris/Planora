    private async Task OpenActivity()
    {
        _showActivity = true;
        _loadingActivity = true;
        _activityError = null;

        try
        {
            _activity = await BoardService.GetActivityAsync(Id) ?? [];
        }
        catch
        {
            _activity = [];
            _activityError = "Could not load board activity.";
        }

        _loadingActivity = false;
    }

    private void CloseActivity()
    {
        _showActivity = false;
        _activityError = null;
    }

    // Wires up SortableJS (wwwroot/js/board-sortable.js) on the rendered column/card lists so
    // dragging follows the mouse and live-reorders, instead of the old "drop only" HTML5 DnD.
    // Both JS functions are idempotent (they skip elements already initialized), so calling them
    // on every render correctly picks up newly added columns/cards without double-wiring.
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
            _jsRef = DotNetObjectReference.Create(this);

        if (_board is not null && _jsRef is not null)
        {
            await JS.InvokeVoidAsync("planoraInitColumnsSortable", _jsRef);
            await JS.InvokeVoidAsync("planoraInitCardLists", _jsRef);
        }

        // Initialize the cropper once the modal (and its <img>) has actually rendered.
        if (_cropperNeedsInit && _cropSrc is not null)
        {
            _cropperNeedsInit = false;
            _cropModule ??= await JS.InvokeAsync<IJSObjectReference>("import", "./js/cover-cropper.js");
            await _cropModule.InvokeVoidAsync("init", _cropImg, _cropSrc);
        }
    }

    [JSInvokable]
    public Task OnColumnsReordered(string columnId, int newIndex)
    {
        if (_board is null || !Guid.TryParse(columnId, out var id)) return Task.CompletedTask;

        var columns = _board.Columns.OrderBy(c => c.Position).ToList();
        var dragged = columns.FirstOrDefault(c => c.Id == id);
        if (dragged is null) return Task.CompletedTask;

        columns.Remove(dragged);
        columns.Insert(Math.Clamp(newIndex, 0, columns.Count), dragged);

        for (var i = 0; i < columns.Count; i++)
        {
            columns[i].Position = i;
            _pendingColumnPositions[columns[i].Id] = i;
        }

        StateHasChanged();
        ScheduleSave();
        return Task.CompletedTask;
    }

    [JSInvokable]
    public Task OnCardsReordered(string cardId, string targetColumnId, int newIndex)
    {
        if (_board is null) return Task.CompletedTask;
        if (!Guid.TryParse(cardId, out var draggedId) || !Guid.TryParse(targetColumnId, out var targetColumnGuid)) return Task.CompletedTask;

        var sourceColumn = _board.Columns.FirstOrDefault(c => c.Cards.Any(card => card.Id == draggedId));
        var targetColumn = _board.Columns.FirstOrDefault(c => c.Id == targetColumnGuid);
        var dragged = sourceColumn?.Cards.FirstOrDefault(card => card.Id == draggedId);
        if (sourceColumn is null || targetColumn is null || dragged is null) return Task.CompletedTask;

        var changedColumn = sourceColumn.Id != targetColumn.Id;
        if (changedColumn)
        {
            sourceColumn.Cards.Remove(dragged);
            dragged.ColumnId = targetColumn.Id;
            targetColumn.Cards.Add(dragged);
        }

        var targetCards = targetColumn.Cards.OrderBy(c => c.Position).ToList();
        targetCards.Remove(dragged);
        targetCards.Insert(Math.Clamp(newIndex, 0, targetCards.Count), dragged);

        for (var i = 0; i < targetCards.Count; i++)
        {
            targetCards[i].Position = i;
            _pendingCardPositions[targetCards[i].Id] = (targetColumn.Id, i);
        }

        if (changedColumn)
        {
            var sourceCards = sourceColumn.Cards.OrderBy(c => c.Position).ToList();
            for (var i = 0; i < sourceCards.Count; i++)
            {
                sourceCards[i].Position = i;
                _pendingCardPositions[sourceCards[i].Id] = (sourceColumn.Id, i);
            }
        }

        StateHasChanged();
        ScheduleSave();
        return Task.CompletedTask;
    }

    private void ScheduleSave()
    {
        _saveCts?.Cancel();
        _saveCts?.Dispose();
        _saveCts = new CancellationTokenSource();
        _ = FlushAfterDelay(_saveCts.Token);
    }

    private async Task FlushAfterDelay(CancellationToken token)
    {
        try { await Task.Delay(800, token); }
        catch (OperationCanceledException) { return; }

        var colSnap = _pendingColumnPositions.ToList();
        _pendingColumnPositions.Clear();
        var cardSnap = _pendingCardPositions.ToList();
        _pendingCardPositions.Clear();

        foreach (var (colId, pos) in colSnap)
        {
            var column = _board?.Columns.FirstOrDefault(c => c.Id == colId);
            if (column is null) continue;

            var updated = await ColumnService.UpdateAsync(colId, new() { RowVersion = column.RowVersion, Position = pos });
            if (updated is not null)
                ApplyColumnUpdate(column, updated);
        }

        foreach (var (cardId, (colId, pos)) in cardSnap)
        {
            var card = FindCard(cardId);
            if (card is null) continue;

            var updated = await CardService.UpdateAsync(cardId, new() { RowVersion = card.RowVersion, ColumnId = colId, Position = pos });
            if (updated is not null)
                ApplyCardUpdate(card, updated);
        }
    }

    public void Dispose()
    {
        _jsRef?.Dispose();
        _saveCts?.Cancel();
        _saveCts?.Dispose();
        if (_cropModule is not null) _ = _cropModule.DisposeAsync();
    }

