@page "/workspaces"
@attribute [Authorize]
@using System.Security.Claims
@using Planora.Shared.Enums

<PageTitle>Workspaces — Planora</PageTitle>

<div class="ws-layout">

    @* ── Sidebar ── *@
    <aside class="ws-sidebar">
        <div class="ws-sidebar-label">Workspaces</div>
        <div class="ws-sidebar-top">
            <button class="ws-new-btn" @onclick="() => _showCreateWs = true">
                <span>+</span> New workspace
            </button>
        </div>
        <div class="ws-nav">
            @if (_loading)
            {
                <div class="text-center py-3"><span class="spinner-border spinner-border-sm"></span></div>
            }
            else
            {
                @foreach (var ws in _workspaces)
                {
                    <button class="ws-nav-item @(_selected?.Id == ws.Id ? "active" : "")"
                            @key="ws.Id"
                            @onclick="() => SelectWorkspace(ws)">
                        <div class="ws-nav-avatar">@ws.Name[0]</div>
                        <span class="ws-nav-name">@ws.Name</span>
                        <button class="ws-nav-delete"
                                title="Delete workspace"
                                @onclick:stopPropagation="true"
                                @onclick="() => ConfirmDeleteWorkspace(ws)">✕</button>
                    </button>
                }
            }
        </div>
    </aside>

    @* ── Main content ── *@
    <div class="ws-content">
        @if (_selected is null)
        {
            <div class="ws-empty">
                <div class="ws-empty-icon">📋</div>
                <div class="ws-empty-text">Select a workspace</div>
                <div class="ws-empty-sub">or create a new one to get started</div>
            </div>
        }
        else
        {
            <div class="ws-content-header">
                <span class="ws-content-title">@_selected.Name</span>
                <div class="ws-content-actions">
                    <button class="btn btn-sm btn-outline-secondary" @onclick="OpenMembersModal">👥 Members</button>
                    <button class="btn btn-sm btn-primary" @onclick="() => _showCreateBoard = true">+ New board</button>
                </div>
            </div>

            @if (_loadingBoards)
            {
                <div class="text-center py-4"><span class="spinner-border spinner-border-sm"></span></div>
            }
            else if (_boards.Count == 0)
            {
                <div class="ws-empty">
                    <div class="ws-empty-icon">🗂</div>
                    <div class="ws-empty-text">No boards yet</div>
                    <div class="ws-empty-sub">Create your first board to start organizing work</div>
                </div>
            }
            else
            {
                <div class="boards-grid">
                    @foreach (var board in _boards)
                    {
                        <div class="board-tile @(_dragOverBoardId == board.Id ? "board-tile--drop" : "")"
                             @key="board.Id"
                             style="@TileStyle(board)"
                             draggable="true"
                             title="Drag to reorder"
                             @ondragstart="() => DragState.DraggedBoardId = board.Id"
                             @ondragend="() => { DragState.DraggedBoardId = null; _dragOverBoardId = null; }"
                             @ondragover:preventDefault
                             @ondragover="() => _dragOverBoardId = board.Id"
                             @ondragleave="() => _dragOverBoardId = null"
                             @ondrop="() => OnBoardDrop(board)"
                             @onclick="() => OpenBoard(board.Id)">
                            <span class="board-tile-name">@board.Name</span>
                        </div>
                    }
                </div>
            }
        }
    </div>
</div>

@* Delete workspace confirmation *@
@if (_deleteTarget is not null)
{
    <div class="modal-backdrop fade show"></div>
    <div class="modal fade show d-block" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered modal-sm">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Delete workspace?</h5>
                    <button class="btn-close" @onclick="() => _deleteTarget = null"></button>
                </div>
                <div class="modal-body">
                    <p style="font-size:13px;color:var(--color-text-mid);">
                        "<strong>@_deleteTarget.Name</strong>" and all its boards will be permanently deleted.
                    </p>
                </div>
                <div class="modal-footer">
                    <button class="btn btn-secondary btn-sm" @onclick="() => _deleteTarget = null">Cancel</button>
                    <button class="btn btn-danger btn-sm" @onclick="DeleteWorkspace" disabled="@_saving">Delete</button>
                </div>
            </div>
        </div>
    </div>
}

@* Create workspace modal *@
@if (_showCreateWs)
{
    <div class="modal-backdrop fade show"></div>
    <div class="modal fade show d-block" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">New Workspace</h5>
                    <button class="btn-close" @onclick="CloseWsModal"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label">Name <span class="text-danger">*</span></label>
                        <input class="form-control" @bind="_wsName" placeholder="e.g. Marketing team" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Description</label>
                        <input class="form-control" @bind="_wsDesc" placeholder="Optional" />
                    </div>
                </div>
                <div class="modal-footer">
                    <button class="btn btn-secondary" @onclick="CloseWsModal">Cancel</button>
                    <button class="btn btn-primary" @onclick="CreateWorkspace" disabled="@(_saving || string.IsNullOrWhiteSpace(_wsName))">Create</button>
                </div>
            </div>
        </div>
    </div>
}

@* Create board modal *@
@if (_showCreateBoard)
{
    <div class="modal-backdrop fade show"></div>
    <div class="modal fade show d-block" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">New Board</h5>
                    <button class="btn-close" @onclick="CloseBoardModal"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label">Name <span class="text-danger">*</span></label>
                        <input class="form-control" @bind="_boardName" placeholder="e.g. Sprint board" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Cover color</label>
                        <input type="color" class="form-control form-control-color" @bind="_boardColor" />
                    </div>
                </div>
                <div class="modal-footer">
                    <button class="btn btn-secondary" @onclick="CloseBoardModal">Cancel</button>
                    <button class="btn btn-primary" @onclick="CreateBoard" disabled="@(_saving || string.IsNullOrWhiteSpace(_boardName))">Create</button>
                </div>
            </div>
        </div>
    </div>
}

@* Members modal *@
@if (_showMembers && _selected is not null)
{
    <div class="modal-backdrop fade show"></div>
    <div class="modal fade show d-block" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered modal-lg">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Members — @_selected.Name</h5>
                    <button class="btn-close" @onclick="CloseMembersModal"></button>
                </div>
                <div class="modal-body">

                    @* Member list *@
                    @if (_loadingMembers)
                    {
                        <div class="text-center py-3"><span class="spinner-border spinner-border-sm"></span></div>
                    }
                    else
                    {
                        <div class="members-list mb-4">
                            @foreach (var member in _members)
                            {
                                <div class="member-item" @key="member.UserId">
                                    <div class="member-avatar">@member.DisplayName[0]</div>
                                    <div class="member-info">
                                        <span class="member-name">@member.DisplayName</span>
                                        <span class="member-email">@member.Email</span>
                                    </div>
                                    <span class="role-badge role-badge--@member.Role.ToString().ToLower()">@member.Role</span>
                                    @if (_callerRole is WorkspaceRole.Owner or WorkspaceRole.Admin
                                         && member.UserId != _selected.OwnerId
                                         && member.UserId != _currentUserId)
                                    {
                                        <button class="member-remove-btn"
                                                title="Remove member"
                                                @onclick="() => RemoveMember(member)"
                                                disabled="@_saving">✕</button>
                                    }
                                </div>
                            }
                        </div>

                        @* Invite section — only for Owner/Admin *@
                        @if (_callerRole is WorkspaceRole.Owner or WorkspaceRole.Admin)
                        {
                            <hr />
                            <div class="invite-section">
                                <h6>Invite someone</h6>
                                <div class="invite-form">
                                    <input class="form-control"
                                           placeholder="Email address"
                                           @bind="_inviteEmail"
                                           type="email" />
                                    <select class="form-select" @bind="_inviteRole">
                                        <option value="@WorkspaceRole.Member">Member</option>
                                        <option value="@WorkspaceRole.Admin">Admin</option>
                                    </select>
                                    <button class="btn btn-primary"
                                            @onclick="SendInvite"
                                            disabled="@(_saving || string.IsNullOrWhiteSpace(_inviteEmail))">
                                        @if (_saving) { <span class="spinner-border spinner-border-sm me-1"></span> }
                                        Invite
                                    </button>
                                </div>
                                @if (_inviteError is not null)
                                {
                                    <div class="alert alert-danger mt-2 py-2" style="font-size:13px;">@_inviteError</div>
                                }
                                @if (_inviteLink is not null)
                                {
                                    <div class="invite-link-box mt-3">
                                        <span class="invite-link-label">Share this link:</span>
                                        <div class="invite-link-row">
                                            <input class="form-control form-control-sm" readonly value="@_inviteLink" />
                                            <button class="btn btn-sm btn-outline-secondary" @onclick="CopyLink">
                                                @(_linkCopied ? "✓ Copied" : "Copy")
                                            </button>
                                        </div>
                                    </div>
                                }
                            </div>
                        }
                    }
                </div>
                <div class="modal-footer">
                    <button class="btn btn-secondary" @onclick="CloseMembersModal">Close</button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    [Inject] WorkspaceService WorkspaceService { get; set; } = null!;
    [Inject] BoardService BoardService { get; set; } = null!;
    [Inject] NavigationManager Nav { get; set; } = null!;
    [Inject] AuthenticationStateProvider AuthStateProvider { get; set; } = null!;
    [Inject] IJSRuntime JS { get; set; } = null!;

    private List<WorkspaceDto> _workspaces = [];
    private List<BoardDto> _boards = [];
    private WorkspaceDto? _selected;
    private WorkspaceDto? _deleteTarget;
    private bool _loading = true;
    private bool _loadingBoards;
    private bool _saving;

    private bool _showCreateWs;
    private string _wsName = "";
    private string _wsDesc = "";

    private bool _showCreateBoard;
    private string _boardName = "";
    private string _boardColor = "#4a5d30";
    private Guid? _dragOverBoardId;

    // Members modal
    private bool _showMembers;
    private bool _loadingMembers;
    private List<WorkspaceMemberDto> _members = [];
    private WorkspaceRole? _callerRole;
    private string? _currentUserId;

    // Invite
    private string _inviteEmail = "";
    private WorkspaceRole _inviteRole = WorkspaceRole.Member;
    private string? _inviteLink;
    private string? _inviteError;
    private bool _linkCopied;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        _currentUserId = authState.User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value
            ?? authState.User.FindFirst("sub")?.Value;

        _workspaces = await WorkspaceService.GetAllAsync() ?? [];
        _loading = false;
        if (_workspaces.Count > 0)
            await SelectWorkspace(_workspaces[0]);
    }

    private async Task SelectWorkspace(WorkspaceDto ws)
    {
        _selected = ws;
        _loadingBoards = true;
        _boards = await WorkspaceService.GetBoardsAsync(ws.Id) ?? [];
        _loadingBoards = false;
    }

    private void ConfirmDeleteWorkspace(WorkspaceDto ws) => _deleteTarget = ws;

    private async Task DeleteWorkspace()
    {
        if (_deleteTarget is null) return;
        _saving = true;
        var ok = await WorkspaceService.DeleteAsync(_deleteTarget.Id);
        if (ok)
        {
            _workspaces.RemoveAll(w => w.Id == _deleteTarget.Id);
            if (_selected?.Id == _deleteTarget.Id)
            {
                _selected = null;
                _boards = [];
            }
        }
        _deleteTarget = null;
        _saving = false;
        if (_selected is null && _workspaces.Count > 0)
            await SelectWorkspace(_workspaces[0]);
    }

    private async Task CreateWorkspace()
    {
        if (string.IsNullOrWhiteSpace(_wsName)) return;
        _saving = true;
        var created = await WorkspaceService.CreateAsync(new() { Name = _wsName, Description = _wsDesc.Length > 0 ? _wsDesc : null });
        if (created is not null) { _workspaces.Add(created); }
        CloseWsModal();
        _saving = false;
        if (created is not null) await SelectWorkspace(created);
    }

    private async Task CreateBoard()
    {
        if (_selected is null || string.IsNullOrWhiteSpace(_boardName)) return;
        _saving = true;
        var created = await BoardService.CreateAsync(new() { Name = _boardName, WorkspaceId = _selected.Id, CoverColor = _boardColor });
        if (created is not null) _boards.Add(created);
        CloseBoardModal();
        _saving = false;
    }

    private async Task OpenMembersModal()
    {
        if (_selected is null) return;
        _showMembers = true;
        _loadingMembers = true;
        _inviteLink = null;
        _inviteError = null;
        _inviteEmail = "";
        _inviteRole = WorkspaceRole.Member;
        _members = await WorkspaceService.GetMembersAsync(_selected.Id) ?? [];
        _callerRole = _members.FirstOrDefault(m => m.UserId == _currentUserId)?.Role;
        _loadingMembers = false;
    }

    private async Task RemoveMember(WorkspaceMemberDto member)
    {
        if (_selected is null) return;
        _saving = true;
        var ok = await WorkspaceService.RemoveMemberAsync(_selected.Id, member.UserId);
        if (ok) _members.RemoveAll(m => m.UserId == member.UserId);
        _saving = false;
    }

    private async Task SendInvite()
    {
        if (_selected is null || string.IsNullOrWhiteSpace(_inviteEmail)) return;
        _saving = true;
        _inviteError = null;
        _inviteLink = null;
        _linkCopied = false;

        var result = await WorkspaceService.CreateInvitationAsync(_selected.Id, new()
        {
            InviteeEmail = _inviteEmail,
            Role = _inviteRole
        });

        if (result is not null)
        {
            _inviteLink = $"{Nav.BaseUri}invite/{result.Token}";
            _inviteEmail = "";
        }
        else
        {
            _inviteError = "Could not send invitation. The user may already be a member or an error occurred.";
        }

        _saving = false;
    }

    private async Task CopyLink()
    {
        if (_inviteLink is null) return;
        await JS.InvokeVoidAsync("navigator.clipboard.writeText", _inviteLink);
        _linkCopied = true;
    }

    private string TileStyle(BoardDto board) =>
        BoardService.ResolveBackgroundStyle(board.CoverImageUrl, board.CoverColor);

    private async Task OnBoardDrop(BoardDto target)
    {
        _dragOverBoardId = null;
        if (DragState.DraggedBoardId is not { } draggedId || draggedId == target.Id) return;
        DragState.DraggedBoardId = null;

        var dragged = _boards.FirstOrDefault(b => b.Id == draggedId);
        if (dragged is null) return;

        _boards.Remove(dragged);
        var targetIndex = _boards.FindIndex(b => b.Id == target.Id);
        _boards.Insert(targetIndex, dragged);

        for (var i = 0; i < _boards.Count; i++)
        {
            if (_boards[i].Position == i) continue;
            _boards[i].Position = i;
            await BoardService.UpdateAsync(_boards[i].Id, new() { Position = i });
        }
    }

    private void OpenBoard(Guid id) => Nav.NavigateTo($"/boards/{id}");
    private void CloseWsModal() { _showCreateWs = false; _wsName = ""; _wsDesc = ""; }
    private void CloseBoardModal() { _showCreateBoard = false; _boardName = ""; _boardColor = "#4a5d30"; }
    private void CloseMembersModal() { _showMembers = false; _members = []; _inviteLink = null; _inviteError = null; }
}
