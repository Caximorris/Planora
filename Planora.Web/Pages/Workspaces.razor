@page "/workspaces"
@attribute [Authorize]
@using Planora.Shared.Constants
@using Planora.Shared.Enums

<PageTitle>Workspaces — Planora</PageTitle>

<div class="ws-layout">

    @* ── Sidebar ── *@
    <aside class="ws-sidebar">
        <div class="ws-sidebar-label">Workspaces</div>
        <div class="ws-sidebar-top">
            <button class="ws-new-btn" @onclick="() => _showCreateWs = true">
                <span>+</span> New workspace
            </button>
        </div>
        <div class="ws-nav">
            @if (_loading)
            {
                <div class="text-center py-3"><span class="spinner-border spinner-border-sm"></span></div>
            }
            else
            {
                @foreach (var ws in _workspaces)
                {
                    <div class="ws-nav-row" @key="ws.Id">
                        <button class="ws-nav-item @(_selected?.Id == ws.Id ? "active" : "")"
                                aria-pressed="@(_selected?.Id == ws.Id)"
                                @onclick="() => SelectWorkspace(ws)">
                            <div class="ws-nav-avatar">@ws.Name[0]</div>
                            <span class="ws-nav-name">@ws.Name</span>
                        </button>
                        <button type="button"
                                class="ws-nav-delete"
                                title="Delete workspace"
                                aria-label="Delete workspace @ws.Name"
                                @onclick="() => ConfirmDeleteWorkspace(ws)">✕</button>
                    </div>
                }
            }
        </div>
    </aside>

    @* ── Main content ── *@
    <div class="ws-content">
        @if (_selected is null)
        {
            <div class="ws-empty">
                <div class="ws-empty-icon">📋</div>
                <div class="ws-empty-text">Select a workspace</div>
                <div class="ws-empty-sub">or create a new one to get started</div>
            </div>
        }
        else
        {
            <div class="ws-content-header">
                <span class="ws-content-title">@_selected.Name</span>
                <div class="ws-content-actions">
                    <button class="btn btn-sm btn-outline-secondary" @onclick="() => OpenSettings(_selected)">⚙ Settings</button>
                    <button class="btn btn-sm btn-outline-secondary" @onclick="ToggleArchivedBoards">
                        @(_showArchivedBoards ? "Hide archived" : "Show archived")
                    </button>
                    <button class="btn btn-sm btn-outline-secondary" @onclick="ToggleTrashBoards">
                        @(_showTrashBoards ? "Hide trash" : "🗑 Trash")
                    </button>
                    <button class="btn btn-sm btn-primary" @onclick="() => _showCreateBoard = true">+ New board</button>
                </div>
            </div>

            @if (_loadingBoards)
            {
                <div class="boards-grid" aria-hidden="true">
                    <div class="skeleton board-tile-skeleton"></div>
                    <div class="skeleton board-tile-skeleton"></div>
                    <div class="skeleton board-tile-skeleton"></div>
                </div>
            }
            else if (_boards.Count == 0)
            {
                <div class="ws-empty">
                    <div class="ws-empty-icon">🗂</div>
                    <div class="ws-empty-text">No boards yet</div>
                    <div class="ws-empty-sub">Create your first board to start organizing work</div>
                </div>
            }
            else
            {
                <div class="boards-grid">
                    @foreach (var board in _boards)
                    {
                        var boardIndex = _boards.IndexOf(board);
                        <div class="board-tile @(_dragOverBoardId == board.Id ? "board-tile--drop" : "")"
                             @key="board.Id"
                             style="@TileStyle(board)"
                             draggable="true"
                             title="Open board. Drag to reorder"
                             role="button"
                             tabindex="0"
                             aria-label="Open board @board.Name"
                             @ondragstart="() => DragState.DraggedBoardId = board.Id"
                             @ondragend="() => { DragState.DraggedBoardId = null; _dragOverBoardId = null; }"
                             @ondragover:preventDefault
                             @ondragover="() => _dragOverBoardId = board.Id"
                             @ondragleave="() => _dragOverBoardId = null"
                             @ondrop="() => OnBoardDrop(board)"
                             @onclick="() => OpenBoard(board.Id)"
                             @onkeydown="e => BoardTileKeyDown(e, board.Id)">
                            <span class="board-tile-name">@board.Name</span>
                            <button type="button"
                                    class="board-tile-archive-btn"
                                    title="Archive board"
                                    aria-label="Archive board @board.Name"
                                    @onclick:stopPropagation="true"
                                    @onclick="() => ArchiveBoard(board)">⬇</button>
                            <div class="board-tile-move">
                                <button type="button" class="board-tile-move-btn"
                                        aria-label="Move @board.Name earlier"
                                        disabled="@(boardIndex <= 0)"
                                        @onclick:stopPropagation="true"
                                        @onclick="() => MoveBoard(board, -1)">‹</button>
                                <button type="button" class="board-tile-move-btn"
                                        aria-label="Move @board.Name later"
                                        disabled="@(boardIndex >= _boards.Count - 1)"
                                        @onclick:stopPropagation="true"
                                        @onclick="() => MoveBoard(board, 1)">›</button>
                            </div>
                        </div>
                    }
                </div>
            }

            @if (_showArchivedBoards)
            {
                <div class="mt-4">
                    <h6 style="font-size:13px;color:var(--text-secondary);margin-bottom:0.5rem;">Archived boards</h6>
                    @if (_loadingArchivedBoards)
                    {
                        <div class="text-center py-2"><span class="spinner-border spinner-border-sm"></span></div>
                    }
                    else if (_archivedBoards.Count == 0)
                    {
                        <p style="font-size:13px;color:var(--text-secondary)">No archived boards.</p>
                    }
                    else
                    {
                        <div class="boards-grid boards-grid--archived">
                            @foreach (var board in _archivedBoards)
                            {
                                <div class="board-tile board-tile--archived" @key="board.Id" style="@TileStyle(board)">
                                    <span class="board-tile-name">@board.Name</span>
                                    <div class="board-tile-archived-actions">
                                        <button class="btn btn-sm btn-light" @onclick="() => UnarchiveBoard(board)">Restore</button>
                                        <button class="btn btn-sm btn-outline-danger" @onclick="() => ConfirmDeleteBoard(board)">Delete</button>
                                    </div>
                                </div>
                            }
                        </div>
                    }
                </div>
            }

            @if (_showTrashBoards)
            {
                <div class="mt-4">
                    <h6 style="font-size:13px;color:var(--text-secondary);margin-bottom:0.5rem;">🗑 Trash</h6>
                    @if (_loadingTrashBoards)
                    {
                        <div class="text-center py-2"><span class="spinner-border spinner-border-sm"></span></div>
                    }
                    else if (_trashedBoards.Count == 0)
                    {
                        <EmptyState Compact Title="Trash is empty"
                                    Description="Deleted boards land here and can be restored.">
                            <Icon>🗑</Icon>
                        </EmptyState>
                    }
                    else
                    {
                        <div class="boards-grid boards-grid--archived">
                            @foreach (var board in _trashedBoards)
                            {
                                <div class="board-tile board-tile--archived" @key="board.Id" style="@TileStyle(board)">
                                    <span class="board-tile-name">@board.Name</span>
                                    <div class="board-tile-archived-actions">
                                        <button class="btn btn-sm btn-light" @onclick="() => RestoreBoard(board)">Restore</button>
                                        <button class="btn btn-sm btn-outline-danger" @onclick="() => ConfirmPermanentDeleteBoard(board)">Delete forever</button>
                                    </div>
                                </div>
                            }
                        </div>
                    }
                </div>
            }
        }
    </div>
</div>

@* Move-to-trash confirmation (soft delete, recoverable) *@
@if (_deleteBoardTarget is not null)
{
    <div class="modal-backdrop fade show"></div>
    <div class="modal fade show d-block" tabindex="-1" role="dialog" aria-modal="true" aria-labelledby="delete-board-title">
        <div class="modal-dialog modal-dialog-centered modal-sm">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="delete-board-title">Move board to Trash?</h5>
                    <button class="btn-close" aria-label="Close delete board dialog" @onclick="() => _deleteBoardTarget = null"></button>
                </div>
                <div class="modal-body">
                    <p style="font-size:13px;color:var(--color-text-mid);">
                        "<strong>@_deleteBoardTarget.Name</strong>" will be moved to the Trash. You can restore it later.
                    </p>
                </div>
                <div class="modal-footer">
                    <button class="btn btn-secondary btn-sm" @onclick="() => _deleteBoardTarget = null">Cancel</button>
                    <button class="btn btn-danger btn-sm" @onclick="DeleteArchivedBoard" disabled="@_saving">Move to Trash</button>
                </div>
            </div>
        </div>
    </div>
}

@* Permanent delete confirmation (irreversible) *@
@if (_permanentDeleteBoardTarget is not null)
{
    <div class="modal-backdrop fade show"></div>
    <div class="modal fade show d-block" tabindex="-1" role="dialog" aria-modal="true" aria-labelledby="perma-delete-board-title">
        <div class="modal-dialog modal-dialog-centered modal-sm">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="perma-delete-board-title">Delete board forever?</h5>
                    <button class="btn-close" aria-label="Close permanent delete dialog" @onclick="() => _permanentDeleteBoardTarget = null"></button>
                </div>
                <div class="modal-body">
                    <p style="font-size:13px;color:var(--color-text-mid);">
                        "<strong>@_permanentDeleteBoardTarget.Name</strong>" and all its data will be permanently deleted. This cannot be undone.
                    </p>
                </div>
                <div class="modal-footer">
                    <button class="btn btn-secondary btn-sm" @onclick="() => _permanentDeleteBoardTarget = null">Cancel</button>
                    <button class="btn btn-danger btn-sm" @onclick="PermanentDeleteBoard" disabled="@_saving">Delete forever</button>
                </div>
            </div>
        </div>
    </div>
}

@* Delete workspace confirmation *@
@if (_deleteTarget is not null)
{
    <div class="modal-backdrop fade show"></div>
    <div class="modal fade show d-block" tabindex="-1" role="dialog" aria-modal="true" aria-labelledby="delete-workspace-title">
        <div class="modal-dialog modal-dialog-centered modal-sm">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="delete-workspace-title">Delete workspace?</h5>
                    <button class="btn-close" aria-label="Close delete workspace dialog" @onclick="() => _deleteTarget = null"></button>
                </div>
                <div class="modal-body">
                    <p style="font-size:13px;color:var(--color-text-mid);">
                        "<strong>@_deleteTarget.Name</strong>" and all its boards will be permanently deleted.
                    </p>
                </div>
                <div class="modal-footer">
                    <button class="btn btn-secondary btn-sm" @onclick="() => _deleteTarget = null">Cancel</button>
                    <button class="btn btn-danger btn-sm" @onclick="DeleteWorkspace" disabled="@_saving">Delete</button>
                </div>
            </div>
        </div>
    </div>
}

@* Create workspace modal *@
@if (_showCreateWs)
{
    <div class="modal-backdrop fade show"></div>
    <div class="modal fade show d-block" tabindex="-1" role="dialog" aria-modal="true" aria-labelledby="create-workspace-title">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="create-workspace-title">New Workspace</h5>
                    <button class="btn-close" aria-label="Close new workspace dialog" @onclick="CloseWsModal"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label">Name <span class="text-danger">*</span></label>
                        <input class="form-control" @bind="_wsName" @bind:event="oninput" placeholder="e.g. Marketing team" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Description</label>
                        <input class="form-control" @bind="_wsDesc" placeholder="Optional" />
                    </div>
                </div>
                <div class="modal-footer">
                    <button class="btn btn-secondary" @onclick="CloseWsModal">Cancel</button>
                    <button class="btn btn-primary" @onclick="CreateWorkspace" disabled="@(_saving || string.IsNullOrWhiteSpace(_wsName))">Create</button>
                </div>
            </div>
        </div>
    </div>
}

@* Create board modal *@
@if (_showCreateBoard)
{
    <div class="modal-backdrop fade show"></div>
    <div class="modal fade show d-block" tabindex="-1" role="dialog" aria-modal="true" aria-labelledby="create-board-title">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="create-board-title">New Board</h5>
                    <button class="btn-close" aria-label="Close new board dialog" @onclick="CloseBoardModal"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label">Name <span class="text-danger">*</span></label>
                        <input class="form-control" @bind="_boardName" @bind:event="oninput" placeholder="e.g. Sprint board" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Cover color</label>
                        <div class="color-swatch-grid" role="radiogroup" aria-label="Board color">
                            @foreach (var color in PlanoraColors.BoardBackgroundColors)
                            {
                                <button type="button"
                                        class="color-swatch color-swatch--board @(IsSelectedBoardColor(color) ? "color-swatch--selected" : "")"
                                        style="@SwatchStyle(color)"
                                        title="@color"
                                        aria-label="Use board color @color"
                                        aria-pressed="@IsSelectedBoardColor(color)"
                                        @onclick="() => _boardColor = color"></button>
                            }
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button class="btn btn-secondary" @onclick="CloseBoardModal">Cancel</button>
                    <button class="btn btn-primary" @onclick="CreateBoard" disabled="@(_saving || string.IsNullOrWhiteSpace(_boardName))">Create</button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    [Inject] WorkspaceService WorkspaceService { get; set; } = null!;
    [Inject] BoardService BoardService { get; set; } = null!;
    [Inject] NavigationManager Nav { get; set; } = null!;
    [Inject] ToastService Toast { get; set; } = null!;

    private List<WorkspaceDto> _workspaces = [];
    private List<BoardDto> _boards = [];
    private WorkspaceDto? _selected;
    private WorkspaceDto? _deleteTarget;
    private bool _loading = true;
    private bool _loadingBoards;
    private bool _saving;

    private bool _showCreateWs;
    private string _wsName = "";
    private string _wsDesc = "";

    private bool _showCreateBoard;
    private string _boardName = "";
    private string _boardColor = PlanoraColors.DefaultBoardColor;
    private Guid? _dragOverBoardId;

    private bool _showArchivedBoards;
    private bool _loadingArchivedBoards;
    private List<BoardDto> _archivedBoards = [];
    private BoardDto? _deleteBoardTarget;

    private bool _showTrashBoards;
    private bool _loadingTrashBoards;
    private List<BoardDto> _trashedBoards = [];
    private BoardDto? _permanentDeleteBoardTarget;

    protected override async Task OnInitializedAsync()
    {
        _workspaces = await WorkspaceService.GetAllAsync() ?? [];
        _loading = false;
        if (_workspaces.Count > 0)
            await SelectWorkspace(_workspaces[0]);
    }

    private async Task SelectWorkspace(WorkspaceDto ws)
    {
        _selected = ws;
        _showArchivedBoards = false;
        _archivedBoards = [];
        _showTrashBoards = false;
        _trashedBoards = [];
        _loadingBoards = true;
        _boards = await WorkspaceService.GetBoardsAsync(ws.Id) ?? [];
        _loadingBoards = false;
    }

    private async Task ToggleArchivedBoards()
    {
        _showArchivedBoards = !_showArchivedBoards;
        if (_showArchivedBoards && _selected is not null)
        {
            _loadingArchivedBoards = true;
            var all = await BoardService.GetByWorkspaceAsync(_selected.Id, includeArchived: true) ?? [];
            _archivedBoards = all.Where(b => b.IsArchived).ToList();
            _loadingArchivedBoards = false;
        }
    }

    private async Task ArchiveBoard(BoardDto board)
    {
        var updated = await BoardService.ArchiveAsync(board.Id);
        if (updated is null) return;
        _boards.RemoveAll(b => b.Id == board.Id);
        if (_showArchivedBoards)
            _archivedBoards.Add(updated);
    }

    private async Task UnarchiveBoard(BoardDto board)
    {
        var updated = await BoardService.UnarchiveAsync(board.Id);
        if (updated is null) return;
        _archivedBoards.RemoveAll(b => b.Id == board.Id);
        _boards.Add(updated);
    }

    private void ConfirmDeleteBoard(BoardDto board) => _deleteBoardTarget = board;

    // Soft delete: moves an archived board to the workspace Trash (recoverable).
    private async Task DeleteArchivedBoard()
    {
        if (_deleteBoardTarget is null) return;
        _saving = true;
        if (await BoardService.DeleteAsync(_deleteBoardTarget.Id))
        {
            _archivedBoards.RemoveAll(b => b.Id == _deleteBoardTarget.Id);
            Toast.Success("Board moved to Trash.");
        }
        else
        {
            Toast.Error("Couldn't move the board to Trash. Please try again.");
        }
        _deleteBoardTarget = null;
        _saving = false;
    }

    private async Task ToggleTrashBoards()
    {
        _showTrashBoards = !_showTrashBoards;
        if (_showTrashBoards && _selected is not null)
        {
            _loadingTrashBoards = true;
            _trashedBoards = await BoardService.GetTrashAsync(_selected.Id) ?? [];
            _loadingTrashBoards = false;
        }
    }

    private async Task RestoreBoard(BoardDto board)
    {
        var restored = await BoardService.RestoreAsync(board.Id);
        if (restored is null)
        {
            Toast.Error("Couldn't restore the board. Please try again.");
            return;
        }
        _trashedBoards.RemoveAll(b => b.Id == board.Id);
        Toast.Success("Board restored.");
        // Restore only clears DeletedAt; the board keeps its archived state, so put it back where
        // it belongs (boards are trashed from the archived view, so this is normally the archive).
        if (restored.IsArchived)
        {
            if (_showArchivedBoards) _archivedBoards.Add(restored);
        }
        else
        {
            _boards.Add(restored);
        }
    }

    private void ConfirmPermanentDeleteBoard(BoardDto board) => _permanentDeleteBoardTarget = board;

    private async Task PermanentDeleteBoard()
    {
        if (_permanentDeleteBoardTarget is null) return;
        _saving = true;
        if (await BoardService.DeletePermanentAsync(_permanentDeleteBoardTarget.Id))
        {
            _trashedBoards.RemoveAll(b => b.Id == _permanentDeleteBoardTarget.Id);
            Toast.Success("Board permanently deleted.");
        }
        else
        {
            Toast.Error("Couldn't delete the board. Please try again.");
        }
        _permanentDeleteBoardTarget = null;
        _saving = false;
    }

    private void ConfirmDeleteWorkspace(WorkspaceDto ws) => _deleteTarget = ws;

    private async Task DeleteWorkspace()
    {
        if (_deleteTarget is null) return;
        _saving = true;
        var ok = await WorkspaceService.DeleteAsync(_deleteTarget.Id);
        if (ok)
        {
            _workspaces.RemoveAll(w => w.Id == _deleteTarget.Id);
            if (_selected?.Id == _deleteTarget.Id)
            {
                _selected = null;
                _boards = [];
            }
        }
        _deleteTarget = null;
        _saving = false;
        if (_selected is null && _workspaces.Count > 0)
            await SelectWorkspace(_workspaces[0]);
    }

    private async Task CreateWorkspace()
    {
        if (string.IsNullOrWhiteSpace(_wsName)) return;
        _saving = true;
        var created = await WorkspaceService.CreateAsync(new() { Name = _wsName, Description = _wsDesc.Length > 0 ? _wsDesc : null });
        if (created is not null) { _workspaces.Add(created); }
        CloseWsModal();
        _saving = false;
        if (created is not null) await SelectWorkspace(created);
    }

    private async Task CreateBoard()
    {
        if (_selected is null || string.IsNullOrWhiteSpace(_boardName)) return;
        _saving = true;
        var created = await BoardService.CreateAsync(new() { Name = _boardName, WorkspaceId = _selected.Id, CoverColor = _boardColor });
        if (created is not null) _boards.Add(created);
        CloseBoardModal();
        _saving = false;
    }

    private void OpenSettings(WorkspaceDto? ws)
    {
        if (ws is null) return;
        Nav.NavigateTo($"/workspaces/{ws.Id}/settings");
    }

    private string TileStyle(BoardDto board) =>
        BoardService.ResolveBackgroundStyle(board.CoverImageUrl, board.CoverColor);

    private static string SwatchStyle(string color) => $"background:{color};";

    private bool IsSelectedBoardColor(string color) =>
        string.Equals(PlanoraColors.SafeBoardBackgroundOrNull(_boardColor), color, StringComparison.OrdinalIgnoreCase);

    private void BoardTileKeyDown(KeyboardEventArgs e, Guid boardId)
    {
        if (e.Key is "Enter" or " " or "Spacebar")
            OpenBoard(boardId);
    }

    private async Task OnBoardDrop(BoardDto target)
    {
        _dragOverBoardId = null;
        if (DragState.DraggedBoardId is not { } draggedId || draggedId == target.Id) return;
        DragState.DraggedBoardId = null;

        var dragged = _boards.FirstOrDefault(b => b.Id == draggedId);
        if (dragged is null) return;

        _boards.Remove(dragged);
        var targetIndex = _boards.FindIndex(b => b.Id == target.Id);
        _boards.Insert(targetIndex, dragged);

        await PersistBoardPositionsAsync();
    }

    // Touch-friendly reorder: HTML5 native drag doesn't fire on touch, so mobile uses the
    // move buttons on each tile (shown only on coarse pointers). See MOBILE_AUDIT P2-6.
    private async Task MoveBoard(BoardDto board, int delta)
    {
        var index = _boards.FindIndex(b => b.Id == board.Id);
        var target = index + delta;
        if (index < 0 || target < 0 || target >= _boards.Count) return;

        _boards.RemoveAt(index);
        _boards.Insert(target, board);
        await PersistBoardPositionsAsync();
    }

    private async Task PersistBoardPositionsAsync()
    {
        for (var i = 0; i < _boards.Count; i++)
        {
            if (_boards[i].Position == i) continue;
            _boards[i].Position = i;
            var updated = await BoardService.UpdateAsync(_boards[i].Id, new() { RowVersion = _boards[i].RowVersion, Position = i });
            if (updated is not null)
            {
                _boards[i].Position = updated.Position;
                _boards[i].RowVersion = updated.RowVersion;
                _boards[i].UpdatedAt = updated.UpdatedAt;
            }
        }
    }

    private void OpenBoard(Guid id) => Nav.NavigateTo($"/boards/{id}");
    private void CloseWsModal() { _showCreateWs = false; _wsName = ""; _wsDesc = ""; }
    private void CloseBoardModal() { _showCreateBoard = false; _boardName = ""; _boardColor = PlanoraColors.DefaultBoardColor; }
}
