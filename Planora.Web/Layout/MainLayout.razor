@inherits LayoutComponentBase
@implements IAsyncDisposable
@using Planora.Shared.DTOs.Notification
@using Planora.Web.Services

<AuthorizeView>
    <Authorized>
        <header class="top-nav">

            <a class="top-nav-brand" href="/">
                <svg class="top-nav-icon" viewBox="0 0 22 18" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                    <rect x="0"   y="2" width="6" height="14" rx="1.5" fill="currentColor"/>
                    <rect x="8"   y="2" width="6" height="9"  rx="1.5" fill="currentColor" opacity=".75"/>
                    <rect x="16"  y="2" width="6" height="11" rx="1.5" fill="currentColor" opacity=".55"/>
                </svg>
                Planora
            </a>

            <nav class="top-nav-links">
                <NavLink class="top-nav-link" href="/workspaces">Workspaces</NavLink>
                <span class="top-nav-link top-nav-link--soon">
                    Templates
                    <span class="nav-soon-badge">Soon</span>
                </span>
                <span class="top-nav-link top-nav-link--soon">
                    Analytics
                    <span class="nav-soon-badge">Soon</span>
                </span>
            </nav>

            <div class="top-nav-spacer"></div>

            @* Notification bell *@
            <div class="nav-notif-wrap">
                <button class="nav-notif-btn" @onclick="ToggleNotifications" title="Notifications" aria-expanded="@_notifOpen">
                    <svg viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true" width="18" height="18">
                        <path d="M10 2a6 6 0 00-6 6v3l-1.5 2.5A1 1 0 003.5 15h13a1 1 0 00.87-1.5L16 11V8a6 6 0 00-6-6z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/>
                        <path d="M8 15.5a2 2 0 004 0" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
                    </svg>
                    @if (NotificationService.UnreadCount > 0)
                    {
                        <span class="nav-notif-badge">@(NotificationService.UnreadCount > 9 ? "9+" : NotificationService.UnreadCount.ToString())</span>
                    }
                </button>

                @if (_notifOpen)
                {
                    <div class="nav-notif-dropdown">
                        <div class="nav-notif-header">
                            <span class="nav-notif-title">Notifications</span>
                            @if (NotificationService.UnreadCount > 0)
                            {
                                <button class="nav-notif-mark-all" @onclick="MarkAllRead">Mark all read</button>
                            }
                        </div>

                        @if (_loadingNotifs)
                        {
                            <div class="nav-notif-empty"><span class="spinner-border spinner-border-sm"></span></div>
                        }
                        else if (_notifications.Count == 0)
                        {
                            <div class="nav-notif-empty">No notifications yet.</div>
                        }
                        else
                        {
                            <div class="nav-notif-list">
                                @foreach (var n in _notifications)
                                {
                                    <div class="nav-notif-item @(n.IsRead ? "" : "nav-notif-item--unread")" @key="n.Id"
                                         @onclick="() => OpenNotification(n)">
                                        <div class="nav-notif-icon">@NotifIcon(n)</div>
                                        <div class="nav-notif-body">
                                            <div class="nav-notif-msg">@n.Message</div>
                                            <div class="nav-notif-time">@TimeAgo(n.CreatedAt)</div>
                                        </div>
                                        <button class="nav-notif-dismiss" title="Dismiss"
                                                @onclick:stopPropagation="true"
                                                @onclick="() => DismissNotification(n)">✕</button>
                                    </div>
                                }
                            </div>
                        }
                    </div>
                    <div class="nav-dropdown-backdrop" @onclick="CloseNotifications"></div>
                }
            </div>

            <div class="nav-user-wrap">
                <button class="nav-user-btn" @onclick="ToggleMenu" aria-expanded="@_open">
                    <div class="nav-avatar">
                        @_initial
                    </div>
                    <span class="nav-name">@_displayName</span>
                    <svg class="nav-chevron @(_open ? "nav-chevron--up" : "")" viewBox="0 0 10 6" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                        <path d="M1 1l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                </button>

                @if (_open)
                {
                    <div class="nav-dropdown">
                        <div class="nav-dropdown-user">
                            <div class="nav-avatar nav-avatar--lg">@_initial</div>
                            <div class="nav-dropdown-user-info">
                                <div class="nav-dropdown-name">@_displayName</div>
                                <div class="nav-dropdown-email">@_email</div>
                            </div>
                        </div>

                        <div class="nav-dropdown-divider"></div>

                        <a class="nav-dropdown-item" href="/profile" @onclick="CloseMenu">
                            <svg viewBox="0 0 16 16" fill="none" aria-hidden="true"><circle cx="8" cy="5" r="3" stroke="currentColor" stroke-width="1.4"/><path d="M2 14c0-3.314 2.686-5 6-5s6 1.686 6 5" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/></svg>
                            Profile &amp; Settings
                        </a>
                        <span class="nav-dropdown-item nav-dropdown-item--disabled">
                            <svg viewBox="0 0 16 16" fill="none" aria-hidden="true"><rect x="2" y="2" width="12" height="12" rx="2" stroke="currentColor" stroke-width="1.4"/><path d="M8 5v3l2 2" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/></svg>
                            What's new
                            <span class="nav-soon-badge">Soon</span>
                        </span>
                        <span class="nav-dropdown-item nav-dropdown-item--disabled">
                            <svg viewBox="0 0 16 16" fill="none" aria-hidden="true"><circle cx="8" cy="8" r="6" stroke="currentColor" stroke-width="1.4"/><path d="M8 7v4M8 5.5v.5" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/></svg>
                            Help &amp; support
                            <span class="nav-soon-badge">Soon</span>
                        </span>

                        <div class="nav-dropdown-divider"></div>

                        <button class="nav-dropdown-item nav-dropdown-item--danger" @onclick="Logout">
                            <svg viewBox="0 0 16 16" fill="none" aria-hidden="true"><path d="M6 2H3a1 1 0 00-1 1v10a1 1 0 001 1h3M10 11l3-3-3-3M13 8H6" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/></svg>
                            Sign out
                        </button>
                    </div>
                    <div class="nav-dropdown-backdrop" @onclick="CloseMenu"></div>
                }
            </div>

        </header>
    </Authorized>
</AuthorizeView>

<main class="main-content">
    <ErrorBoundary @ref="_errorBoundary">
        <ChildContent>@Body</ChildContent>
        <ErrorContent>
            <div style="display:flex;flex-direction:column;align-items:center;justify-content:center;height:50vh;gap:1rem;">
                <p style="color:var(--text-secondary)">Something went wrong. Please try again.</p>
                <button class="btn btn-sm btn-outline-secondary" @onclick="RecoverFromError">Retry</button>
            </div>
        </ErrorContent>
    </ErrorBoundary>
</main>

@code {
    [Inject] AuthService AuthService { get; set; } = null!;
    [Inject] NavigationManager Nav { get; set; } = null!;
    [Inject] NotificationService NotificationService { get; set; } = null!;
    [CascadingParameter] private Task<AuthenticationState> AuthState { get; set; } = null!;

    private bool _open;
    private string _displayName = "";
    private string _email = "";
    private string _initial = "?";
    private bool _notifStarted;

    private ErrorBoundary? _errorBoundary;
    private void RecoverFromError() => _errorBoundary?.Recover();

    private bool _notifOpen;
    private bool _loadingNotifs;
    private List<NotificationDto> _notifications = [];

    protected override async Task OnParametersSetAsync()
    {
        var state = await AuthState;
        _displayName = state.User.FindFirst("displayName")?.Value ?? "";
        _email       = state.User.FindFirst("email")?.Value ?? "";
        _initial     = _displayName.Length > 0 ? _displayName[0].ToString().ToUpper() : "?";

        if (state.User.Identity?.IsAuthenticated == true && !_notifStarted)
        {
            _notifStarted = true;
            NotificationService.OnChange += OnNotifCountChanged;
            NotificationService.StartPolling();
        }
    }

    private void OnNotifCountChanged() => InvokeAsync(StateHasChanged);

    private async Task ToggleNotifications()
    {
        _notifOpen = !_notifOpen;
        _open = false;
        if (_notifOpen) await LoadNotificationsAsync();
    }

    private void CloseNotifications() => _notifOpen = false;

    private async Task LoadNotificationsAsync()
    {
        _loadingNotifs = true;
        _notifications = await NotificationService.GetRecentAsync() ?? [];
        _loadingNotifs = false;
    }

    private async Task OpenNotification(NotificationDto n)
    {
        if (!n.IsRead)
        {
            await NotificationService.MarkReadAsync(n.Id);
            n.IsRead = true;
        }
        _notifOpen = false;

        if (n.RelatedBoardId.HasValue)
            Nav.NavigateTo($"/boards/{n.RelatedBoardId}");
        else if (n.RelatedWorkspaceId.HasValue)
            Nav.NavigateTo("/workspaces");
    }

    private async Task MarkAllRead()
    {
        await NotificationService.MarkAllReadAsync();
        foreach (var n in _notifications) n.IsRead = true;
    }

    private async Task DismissNotification(NotificationDto n)
    {
        await NotificationService.DeleteAsync(n.Id, wasUnread: !n.IsRead);
        _notifications.Remove(n);
    }

    private static string NotifIcon(NotificationDto n) => n.Type switch
    {
        Planora.Shared.Enums.NotificationType.AssignedToCard => "👤",
        Planora.Shared.Enums.NotificationType.NewComment     => "💬",
        _                                                     => "🔔"
    };

    private static string TimeAgo(DateTime utc)
    {
        var diff = DateTime.UtcNow - utc;
        if (diff.TotalMinutes < 1) return "just now";
        if (diff.TotalHours < 1) return $"{(int)diff.TotalMinutes}m ago";
        if (diff.TotalDays < 1) return $"{(int)diff.TotalHours}h ago";
        if (diff.TotalDays < 7) return $"{(int)diff.TotalDays}d ago";
        return utc.ToLocalTime().ToString("MMM d");
    }

    private void ToggleMenu() { _open = !_open; _notifOpen = false; }
    private void CloseMenu()  => _open = false;

    private async Task Logout()
    {
        _open = false;
        await AuthService.LogoutAsync();
        Nav.NavigateTo("/login");
    }

    public async ValueTask DisposeAsync()
    {
        NotificationService.OnChange -= OnNotifCountChanged;
        await NotificationService.DisposeAsync();
    }
}
