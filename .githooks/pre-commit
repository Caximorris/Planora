#!/usr/bin/env sh
set -eu

ROOT="$(git rev-parse --show-toplevel)"

if command -v pwsh >/dev/null 2>&1; then
  exec pwsh -NoProfile -File "$ROOT/scripts/Invoke-PlanoraQuality.ps1" -Gate commit
fi

if command -v powershell.exe >/dev/null 2>&1; then
  exec powershell.exe -NoProfile -ExecutionPolicy Bypass -File "$ROOT/scripts/Invoke-PlanoraQuality.ps1" -Gate commit
fi

echo "Planora pre-commit requires PowerShell (pwsh or powershell.exe)." >&2
exit 1
